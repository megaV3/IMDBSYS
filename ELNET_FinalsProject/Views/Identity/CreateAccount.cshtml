@model ELNET_FinalsProject.Models.User
@{
    ViewData["Title"] = "Create Account";
    Layout = null;
}
<link rel="stylesheet" href="~/css/CreateAccount.css" />

<div class="page-wrapper">

    <!-- Left Panel -->
    <div class="left-panel">
        <h1 class="brand-name">PICKOUT<br>COFFEE</h1>
        <p class="brand-tagline">it's always premium espresso in<br>every cup while you are on the go.</p>
    </div>

    <!-- Right Panel -->
    <div class="right-panel">

        <a asp-action="Index" asp-controller="Home" class="btn-back">
            &#8592; Back
        </a>

        <div class="form-container">

            <h2 class="form-title">Create Account</h2>
            <p class="form-subtitle">Sign up to start your coffee journey</p>

            <form asp-action="CreateAccount" method="post">

                <div class="two-columns">
                    <div class="field">
                        <label>First Name</label>
                        <input asp-for="FirstName" placeholder="Juan" />
                        <span asp-validation-for="FirstName" class="error"></span>
                    </div>
                    <div class="field">
                        <label>Last Name</label>
                        <input asp-for="LastName" placeholder="Dela Cruz" />
                        <span asp-validation-for="LastName" class="error"></span>
                    </div>
                </div>

                <div class="field">
                    <label>Username</label>
                    <input asp-for="Username" placeholder="juandelacruz" />
                    <span asp-validation-for="Username" class="error"></span>
                </div>

                <div class="field">
                    <label>Email</label>
                    <input asp-for="Email" placeholder="juan@email.com" />
                    <span asp-validation-for="Email" class="error"></span>
                </div>

                <div class="two-columns">
                    <div class="field">
                        <label>Password</label>
                        <input asp-for="Password" type="password" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="error"></span>
                    </div>
                    <div class="field">
                        <label>Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="error"></span>
                    </div>
                </div>

                <button type="submit" class="btn-submit">Create Account</button>

            </form>

            @if (ViewBag.Error != null)
            {
                <div class="error-alert">@ViewBag.Error</div>
            }

            <p class="signin-link">
                Already have an account? <a asp-action="Login">Sign in</a>
            </p>

        </div>
    </div>
</div>

