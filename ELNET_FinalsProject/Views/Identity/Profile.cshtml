
@{
    ViewData["Title"] = "Profile";
}

<div class ="navbar">

    <div class="nav-left">
        <h2>PICKOUT COFFEE</h2>
    </div>

    <div class="nav-center">
        <a asp-controller="Store" asp-action="Index" class="nav-link active">Home</a>
    </div>

    <div class="nav-right">
        <a asp-controller="Order" asp-action="Cart" class="nav-icon active-cart">
            🛒
        </a> 
        <a asp-controller="Identity" asp-action="Profile" class="nav-icon active-profile">
            👤
        </a>
    </div>

</div>
<style>
    .navbar {
        display: flex;
        justify-content: space-between;
        position: sticky; /*sticks to one place whenever you scroll*/
        top: 0;           /*sticks at the top*/
        z-index: 100;     /*ensures that it stays above other content*/
        background-color: #f5f5f5;
        
        padding: 10px 30px;
        color: #9caf6c;
    }

    .nav-center {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
    }

    .nav-link {
        text-decoration: none;
        color: #9caf6c;
        padding: 5px 20px;
        border-radius: 30px;
        transition: 0.3s ease;
    }

    .nav-link:hover {
        background: #9caf6c;
        text-decoration: none;
        color: white;
    }

    .nav-link.active {
        border: 2px solid #9caf6c;
    }

    .active-profile {
        background: #9caf6c;
        border: 2px solid #9caf6c;
        transition: 0.3s ease;
    }

    .nav-left h2 {
        margin: 0;
        font-weight: bold;
        font-size: 25px;
    }

    .nav-right {
        display: flex;
        gap: 20px;
    }

    .nav-icon {
        text-decoration: none;
        font-size: 25px;
        /* These 3 lines center the 🛒 perfectly */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        /* This is the secret: it keeps the bubble relative to the icon */
        position: relative;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        transition: 0.3s ease;
    }

    .nav-icon:hover {
         text-decoration: none;
         background: #9caf6c;
    }

    body {
        background: white;
        font-family: Arial, sans-serif;
        margin: 0;
    }

    .profile-page {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
        margin-bottom: 50px;
    }

    .profile-card {
        width: 500px;
        background: #9caf6c;
        border-radius: 30px;
        padding: 40px 35px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        box-sizing: border-box;
    }

    .profile-image-section {
        position: relative;
        width: fit-content;
        margin: auto;
        margin-bottom: 20px;
    }

    .profile-image {
        width: 95px;
        height: 95px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid white;
    }

    .edit-icon {
        position: absolute;
        bottom: 0;
        right: 0;
        background: white;
        color: #9caf6c;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 17px;
    }

    .profile-card h2 {
        font-weight: bold;
        margin-bottom: 8px;
        color: white;
    }

    .profile-subtitle {
        color: white;
        font-size: 14px;
        margin-bottom: 30px;
    }

    .input-group {
        width: 100%;
        text-align: left;
        margin-bottom: 16px;
    }
    
    .input-group label {
        font-size: 13px;
        color: antiquewhite;
        display: block;
        margin-bottom: 8px;
    }

    .input-group input {
        width: 100%;
        padding: 20px 22px;
        border: 2px solid #ddd;
        border-radius: 20px !important;
        outline: none;
        font-size: 16px;
        box-sizing: border-box;
    }

    .readonly-input {
        background: #efefef;
        cursor: not-allowed;
    }

    <!--wala pani gamit ang topup-btn-->
    .topup-btn {
        display: inline-block;
        margin-top: 10px;
        margin-bottom: 25px;
        background: #dfe7c7;
        color: #556b2f;
        padding: 10px 20px;
        border-radius: 20px;
        text-decoration: none;
        font-weight: bold;
    }

    .save-btn {
        width: 100%;
        background: white;
        color: #556b2f;
        border: none;
        padding: 14px;
        border-radius: 25px;
        font-size: 15px;
        cursor: pointer;
        transition: 0.3s ease;
        margin-top: 50px;
        margin-bottom: 20px;
    }

    .save-btn:hover {
        background: #85995b;
        color: white;
    }

    .logout-btn {
        display: inline-block;
        color: #ff0000;
        text-decoration: none;
        font-size: 14px;
    }

</style>

<div class="profile-page">
    <div class="profile-card">


        <!--prof image-->
        <div class="profile-image-section">

            <img id="previewImage" src="@(string.IsNullOrEmpty(Model.ProfileImagePath) ? "/images/default-avatar.png" : Model.ProfileImagePath)"
                 class="profile-image"/>

            <label for="profileUpload" class="edit-icon">
                ✎
            </label>

            <input type="file"
                   id="profileUpload"
                   name="profileImage"
                   accept="image/*"
                   hidden
                   onchange="previewProfileImage(event)" />

        </div>

        <!--title-->
        <h2>Your Profile</h2>

        <p class="profile-subtitle">
            Update your details for a personalized brew experience.
        </p>

        <!--form-->
        <form asp-action="Profile"
              asp-controller="Identity"
              method="post"
              enctype="multipart/form-data">

             <!--first name-->
            <div class="input-group">
                <label>First Name</label>

                <input type="text"
                       name="FirstName"
                       value="@Model.FirstName" />
            </div>

            <!--first name-->
            <div class="input-group">
                <label>Last Name</label>

                <input type="text"
                       name="LastName"
                       value="@Model.LastName" />
            </div>

            <!-- EMAIL -->
            <div class="input-group">
                <label>Email Address</label>

                <input type="email"
                       value="@Model.Email"
                       readonly
                       class="readonly-input" />
            </div>

            <!-- SAVE CHANGES -->
            <button type="submit" class="save-btn">
                Save Changes
            </button>

            
        </form>
        <!-- SIGN OUT -->
        <form asp-controller="Identity"
              asp-action="Logout" method="post">
            <button type="submit" class="logout-btn" style="background:none; cursor:pointer; border:none;">
                Sign Out
            </button>
        </form>
    </div>
</div>

<script>

    function previewProfileImage(event) {

        const image = document.getElementById("previewImage");

        image.src = URL.createObjectURL(event.target.files[0]);
    }

</script>