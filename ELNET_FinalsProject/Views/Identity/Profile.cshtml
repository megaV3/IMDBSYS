@model ELNET_FinalsProject.ViewModels.ProfileViewModel
@await Html.PartialAsync("_TopUpModal", new ELNET_FinalsProject.ViewModels.TopUpViewModel()
{
    Email = Model.Email
})

@{
    ViewData["Title"] = "Profile";
}


<link href="~/css/profile.css" rel="stylesheet" />

<div class ="navbar">

    <div class="nav-left">
        <h2>PICKOUT COFFEE</h2>
    </div>

    <div class="nav-center">
        <a asp-controller="Store" asp-action="Index" class="nav-link active">Home</a>
    </div>

    <div class="nav-right">
        <a asp-controller="Order" asp-action="Cart" class="nav-icon">
            🛒
            <span id="cart-count" style="
                position: absolute;
                top: 0;
                right: 0;
                font-size: 10px;
                background: #3e4e2c;
                color: white;
                border-radius: 50%;
                padding: 2px 5px;
                line-height: 1;
                transform: translate(25%, -25%);">
                @Model.CartCount
            </span>
        </a>
        <a asp-controller="Identity" asp-action="Profile" class="nav-icon active-profile">
            <img class="nav-icon active-profile" src="@Url.Content(Model.ProfileImagePath)" />
        </a>
    </div>

</div>
<style>
</style>

<div class="profile-page">
    <div class="profile-card">
        
        <!--form-->
        <form asp-action="Profile"
              asp-controller="Identity"
              method="post"
              enctype="multipart/form-data">


            <!--prof image-->
            <div class="profile-image-section">
            
                <!--
                <img id="previewImage" src="~(string.IsNullOrEmpty(Model.ProfileImagePath) ? "/images/default-avatar.png" : Model.ProfileImagePath)"
                     class="profile-image" />
                -->

                <img id="previewImage" src="@Url.Content(Model.ProfileImagePath)"
                     class="profile-image" />

                <label for="profileUpload" class="edit-icon">
                    ✎
                </label>

                <input type="file"
                       id="profileUpload"
                       name="profileImage"
                       accept="image/*"
                       hidden
                       onchange="previewProfileImage(event)" />

            </div>

            <!--title-->
            <h2>Your Profile</h2>

            <p class="profile-subtitle">
                Update your details for a personalized brew experience.
            </p>

            <div class="wallet-box">

                <div class="wallet-left">

                    <p>My Coffee Wallet</p>

                    <h2>₱@Model.Balance</h2>

                </div>

                @* <a asp-action="TopUp" class="topup-btn">
                    + Top Up Balance
                </a> *@
                @* <button type="button"
                        class="topup-btn"
                        data-bs-toggle="modal"
                        data-bs-target="#topUpModal">
                    + Top Up Balance
                </button> *@
                @* <button type="button"
                        class="topup-btn"
                        data-toggle="modal"
                        data-target="#topUpModal">
                    + Top Up Balance
                </button> *@
                <button type="button" class="topup-btn" onclick="openTopUpModal()">
                    + Top Up Balance
                </button>
            </div>

             <!--first name-->
            <div class="input-group">
                <label>First Name</label>

                <input type="text"
                       name="FirstName"
                       value="@Model.FirstName" />
            </div>

            <!--first name-->
            <div class="input-group">
                <label>Last Name</label>

                <input type="text"
                       name="LastName"
                       value="@Model.LastName" />
            </div>

            <!-- EMAIL -->
            <div class="input-group">
                <label>Email Address</label>

                <input type="email"
                       value="@Model.Email"
                       readonly
                       class="readonly-input" />
            </div>

            <!-- SAVE CHANGES -->
            <button type="submit" class="save-btn">
                Save Changes
            </button>

            <div asp-validation-summary="All"></div>

            
        </form>
        <!-- SIGN OUT -->
        <form asp-controller="Identity"
              asp-action="Logout" method="post">
            <button type="submit" class="logout-btn" style="background:none; cursor:pointer; border:none;">
                Sign Out
            </button>
        </form>
    </div>
</div>
@* @await Html.PartialAsync("_TopUpModal", new ELNET_FinalsProject.ViewModels.TopUpViewModel()) *@
<script>

    function previewProfileImage(event) {

        const image = document.getElementById("previewImage");

        image.src = URL.createObjectURL(event.target.files[0]);
    }
    
    function updateCartCount(added) {
        var el = document.getElementById('cart-count');
        if (el) {
            el.textContent = (parseInt(el.textContent) || 0) + added;
        }
    }

        function openTopUpModal() {
        document.getElementById('topUpOverlay').style.display = 'flex';
        document.body.style.overflow = 'hidden'; // Stop scrolling
    }

    function closeTopUpModal() {
        document.getElementById('topUpOverlay').style.display = 'none';
        document.body.style.overflow = ''; // Resume scrolling
    }

    function handleTopUpOverlayClick(e) {
        if (e.target === document.getElementById('topUpOverlay')) {
            closeTopUpModal();
        }
    }

</script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}