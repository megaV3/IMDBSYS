@model ELNET_FinalsProject.ViewModels.ProfileViewModel
@await Html.PartialAsync("_TopUpModal", new ELNET_FinalsProject.ViewModels.TopUpViewModel()
{
    Email = Model.Email
})

@{
    ViewData["Title"] = "Profile";
}


<link href="~/css/profile.css" rel="stylesheet" />

<div class ="navbar">

    <div class="nav-left">
        <h2>PICKOUT COFFEE</h2>
    </div>

    <div class="nav-center">
        <a asp-controller="Store" asp-action="Index" class="nav-link active">Home</a>
    </div>

    <div class="nav-right">
        
        <a asp-controller="Order" asp-action="Cart" style="position:relative; display:inline-block;">
            <!-- Wrap only the images in the circular div -->
            <div class="cart-wrapper">
                <img class="cart-img default-img" src="~/images/cart-grey.png" alt="Cart" />
                <img class="cart-img hover-img" src="~/images/cart-green.png" alt="Cart Hover" />
            </div>

            <!-- Badge stays outside the circular clip -->
            <span id="cart-count" style="
                position: absolute;
                top: 0;
                right: 11px;
                font-size: 10px;
                background: #3e4e2c;
                color: white;
                border-radius: 50%;
                padding: 2px 5px;
                line-height: 1;
                transform: translate(25%, -25%);
                z-index: 10;">
                @Model.CartCount
            </span>
        </a>
        <a asp-controller="Identity" asp-action="Profile" class="nav-icon active-profile">
            <img class="nav-icon active-profile" src="@Url.Content(Model.ProfileImagePath)" />
        </a>
    </div>

</div>
<style>
    .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #f5f5f5;
        height: 70px;
           /*(100vw - 100%) calculates the exact width of the scrollbar dynamically. */
        padding-left: 30px;
        padding-right: calc(30px + (100vw - 100%));
        color: #9caf6c;
    }

    .nav-center {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
    }

    .nav-link {
        text-decoration: none;
        color: #9caf6c;
        padding: 5px 20px;
        border-radius: 30px;
        transition: 0.3s ease;
    }

        .nav-link:hover {
            background: #9caf6c;
            text-decoration: none;
            color: white;
        }

        .nav-link.active {
            border: 2px solid #9caf6c;
        }

    .active-profile {
        border: 1px solid #9caf6c;
    }

    .nav-left h2 {
        margin: 0;
        font-weight: bold;
        font-size: 25px;
    }

    .nav-right {
        flex: 1; /* Takes up 1/3 of space */
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 2px;
    }

    .cart-wrapper, .profile-wrapper {
        position: relative;
        display: inline-block;
        width: 40px; /* Set a fixed size for a perfect circle */
        height: 40px;
        vertical-align: middle;
        margin: 0 10px;
        /* This creates the rounded shape */
        border-radius: 50%;
        overflow: hidden; /* Ensures nothing spills out of the circle */
        background-color: transparent; /* Or a light background if your PNGs have transparency */
    }

    .cart-img, .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* 'cover' is better for rounded icons to ensure they fill the circle */
        border-radius: 50%; /* Double-ensure the images are rounded */
        transition: opacity 0.3s ease;
    }

    .hover-img {
        position: absolute;
        top: 0;
        left: 0;
        opacity: 0;
        z-index: 2;
    }

    .default-img {
        position: relative;
        opacity: 1;
        z-index: 1;
    }

    /* Hover States */
    .cart-wrapper:hover .hover-img,
    .profile-wrapper:hover .hover-img {
        opacity: 1;
    }

    .cart-wrapper:hover .default-img,
    .profile-wrapper:hover .default-img {
        opacity: 0;
    }

    /* Keep the cart badge outside the 'overflow:hidden' of the wrapper
                   by moving it to the anchor tag instead */
    #cart-count {
        z-index: 10;
        /* Ensure this stays visible even if the wrapper clips images */
    }

    .nav-icon {
        text-decoration: none;
        font-size: 25px;
        /* These 3 lines center the 🛒 perfectly */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        /* This is the secret: it keeps the bubble relative to the icon */
        position: relative;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        transition: 0.3s ease;
    }

        .nav-icon img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* This is the magic line */
            border-radius: 50%; /* Ensures the image itself is also clipped to a circle */
        }

    body {
        background: white;
        font-family: Arial, sans-serif;
        margin: 0;
    }

    .profile-page {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 20px;
        margin-bottom: 50px;
    }

    .profile-card {
        width: 500px;
        background: #9caf6c;
        border-radius: 30px;
        padding: 40px 35px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        box-sizing: border-box;
    }

    .profile-image-section {
        position: relative;
        width: fit-content;
        margin: auto;
        margin-bottom: 20px;
    }

    .profile-image {
        width: 95px;
        height: 95px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid white;
    }

    .edit-icon {
        position: absolute;
        bottom: 0;
        right: 0;
        background: white;
        color: #9caf6c;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 17px;
    }

    .profile-card h2 {
        font-weight: bold;
        margin-bottom: 8px;
        color: white;
    }

    .profile-subtitle {
        color: white;
        font-size: 14px;
        margin-bottom: 30px;
    }

    .input-group {
        width: 100%;
        text-align: left;
        margin-bottom: 16px;
    }

        .input-group label {
            font-size: 13px;
            color: antiquewhite;
            display: block;
            margin-bottom: 8px;
        }

        .input-group input {
            width: 100%;
            padding: 20px 22px;
            border: 2px solid #ddd;
            border-radius: 20px !important;
            outline: none;
            font-size: 16px;
            box-sizing: border-box;
        }

    .readonly-input {
        background: #efefef;
        cursor: not-allowed;
    }

    .save-btn {
        width: 100%;
        background: white;
        color: #556b2f;
        border: none;
        padding: 14px;
        border-radius: 25px;
        font-size: 15px;
        cursor: pointer;
        transition: 0.3s ease;
        margin-top: 30px;
        margin-bottom: 10px;
    }

        .save-btn:hover {
            background: #85995b;
            color: white;
        }

    .logout-btn {
        display: inline-block;
        color: #ff0000;
        text-decoration: none;
        font-size: 14px;
    }

    .wallet-box {
        background: rgba(255,255,255,0.15);
        border: 2px solid rgba(255,255,255,0.5);
        border-radius: 25px;
        padding: 18px 22px;
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        backdrop-filter: blur(10px);
    }

    .wallet-left p {
        margin: 0;
        color: white;
        font-size: 15px;
    }

    .wallet-left h2 {
        margin: 5px 0 0 0;
        color: white;
        font-size: 30px;
        font-weight: 900;
    }

    .topup-btn {
        text-decoration: none;
        background: white;
        color: #5f7338;
        padding: 6px 15px;
        border-radius: 20px;
        font-weight: bold;
    }

        .topup-btn:hover {
            text-decoration: none;
            background: #f5f5f5;
            color: #5f7338;
        }

    /* This forces the modal to sit ON TOP of your green card and navbar */
    /* .modal-backdrop {
            z-index: 10000 !important;
        }

        #topUpModal {
            z-index: 10001 !important;
            background-color: white !important;
            width: 500px;
            margin-left: -250px; /* Centers the modal
            top: 25% !important;
        } */

    /* Ensure form inputs are visible
            #topUpModal input {
                display: block !important;
                visibility: visible !important;
            } */

    /* Custom Modal Styling (Matches Basket Modal) */
    .custom-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(62, 78, 44, 0.55);
        z-index: 9999;
        align-items: center;
        justify-content: center;
    }

    .custom-modal-content {
        background: #fff;
        border-radius: 24px;
        width: 92%;
        max-width: 400px;
        padding: 30px;
        box-shadow: 0 24px 60px rgba(62, 78, 44, 0.25);
        animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    .modal-header-custom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .close-custom {
        background: none;
        border: none;
        font-size: 28px;
        cursor: pointer;
        color: #aaa;
    }

    .modal-input {
        width: 100%;
        padding: 12px;
        border: 2px solid #dde8c5;
        border-radius: 12px;
        font-size: 18px;
        box-sizing: border-box;
    }

    .modal-footer-custom {
        display: flex;
        gap: 10px;
        margin-top: 25px;
    }

    .btn-cancel-custom {
        flex: 1;
        padding: 12px;
        border-radius: 12px;
        border: 1.5px solid #dde8c5;
        background: #fff;
        cursor: pointer;
    }

    .btn-confirm-custom {
        flex: 1;
        padding: 12px;
        border-radius: 12px;
        border: none;
        background: #9caf6c;
        color: white;
        font-weight: bold;
        cursor: pointer;
    }

</style>

<div class="profile-page">
    <div class="profile-card">
        
        <!--form-->
        <form asp-action="Profile"
              asp-controller="Identity"
              method="post"
              enctype="multipart/form-data">


            <!--prof image-->
            <div class="profile-image-section">
            
                <!--
                <img id="previewImage" src="~(string.IsNullOrEmpty(Model.ProfileImagePath) ? "/images/default-avatar.png" : Model.ProfileImagePath)"
                     class="profile-image" />
                -->

                <img id="previewImage" src="@Url.Content(Model.ProfileImagePath)"
                     class="profile-image" />

                <label for="profileUpload" class="edit-icon">
                    ✎
                </label>

                <input type="file"
                       id="profileUpload"
                       name="profileImage"
                       accept="image/*"
                       hidden
                       onchange="previewProfileImage(event)" />

            </div>

            <!--title-->
            <h2>Your Profile</h2>

            <p class="profile-subtitle">
                Update your details for a personalized brew experience.
            </p>

            <div class="wallet-box">

                <div class="wallet-left">

                    <p>My Coffee Wallet</p>

                    <h2>₱@Model.Balance</h2>

                </div>

                @* <a asp-action="TopUp" class="topup-btn">
                    + Top Up Balance
                </a> *@
                @* <button type="button"
                        class="topup-btn"
                        data-bs-toggle="modal"
                        data-bs-target="#topUpModal">
                    + Top Up Balance
                </button> *@
                @* <button type="button"
                        class="topup-btn"
                        data-toggle="modal"
                        data-target="#topUpModal">
                    + Top Up Balance
                </button> *@
                <div class="wallet-right">
                    <button type="button" class="topup-btn" onclick="openTopUpModal()">
                        + Top Up Balance
                    </button>
                    <button type="button" class="history-link-btn" onclick="openHistoryModal()">
                        View History
                    </button>
                </div>
            </div>

            <a asp-controller="Order" asp-action="History" class="history-btn">
                <i class="fa-regular fa-file-lines"></i>
                View Order History
            </a>

             <!--first name-->
            <div class="input-group">
                <label>First Name</label>

                <input type="text"
                       name="FirstName"
                       value="@Model.FirstName" />
            </div>

            <!--last name-->
            <div class="input-group">
                <label>Last Name</label>

                <input type="text"
                       name="LastName"
                       value="@Model.LastName" />
            </div>

            <!-- EMAIL -->
            <div class="input-group">
                <label>Email Address</label>

                <input type="email"
                       value="@Model.Email"
                       readonly
                       class="readonly-input" />
            </div>

            <!-- SAVE CHANGES -->
            <button type="submit" class="save-btn">
                Save Changes
            </button>
            
            @if (ViewBag.IsProfileUpdated != null && ViewBag.IsProfileUpdated)
            {
                <div class="badge bg-success">
                    Profile updated successfully!
                </div>
            }
            else if (ViewBag.IsNameSame != null && ViewBag.IsNameSame)
            {
                <div class="badge bg-danger">
                    Name is still the same!
                </div>
            }

            <div asp-validation-summary="All"></div>

            
        </form>
        <!-- SIGN OUT -->
        <form asp-controller="Identity"
              asp-action="Logout" method="post">
            <button type="submit" class="logout-btn" style="background:none; cursor:pointer; border:none;">
                Sign Out
            </button>
        </form>
    </div>
</div>

<!-- HISTORY MODAL -->
<div id="historyOverlay" style="display:none; position:fixed; inset:0;
     background:rgba(62,78,44,0.55); z-index:9999; align-items:center;
     justify-content:center;" onclick="handleHistoryOverlayClick(event)">
    <div style="background:#fff; border-radius:24px; width:92%; max-width:460px;
                overflow:hidden; box-shadow:0 24px 60px rgba(62,78,44,0.25);
                animation: modalIn 0.3s cubic-bezier(0.34,1.56,0.64,1) both;">

        <!-- Modal Header -->
        <div style="background:#9caf6c; padding:18px 24px; display:flex;
                    justify-content:space-between; align-items:center;">
            <span style="color:white; font-size:18px; font-weight:bold;">
                📋 Top Up History
            </span>
            <button onclick="closeHistoryModal()" style="background:none; border:none;
                    color:white; font-size:28px; cursor:pointer; line-height:1;">
                ×
            </button>
        </div>

        <!-- Modal Body -->
        <div style="padding:20px 24px; max-height:420px; overflow-y:auto;">
            @if (Model.TopUpHistory != null && Model.TopUpHistory.Any())
            {
                @foreach (var tx in Model.TopUpHistory)
                {
                    <div style="display:flex; justify-content:space-between; align-items:center;
                                        padding:12px 14px; border-radius:14px; margin-bottom:10px;
                                        background:#f7faf0; border:1px solid #dde8c5;">
                        <div style="display:flex; flex-direction:column; gap:3px;">
                            <span style="font-weight:bold; color:#3e4e2c; font-size:14px;">
                                @tx.PaymentMethod
                            </span>
                            <span style="font-size:11px; color:#aaa;">
                                @tx.TransactionDate.ToString("MMM dd, yyyy • h:mm tt")
                            </span>
                        </div>
                        <div style="display:flex; flex-direction:column; align-items:flex-end; gap:4px;">
                            <span style="font-weight:900; color:#3e4e2c; font-size:15px;">
                                +₱@tx.Amount.ToString("0.00")
                            </span>
                            <span style="font-size:11px; padding:2px 10px; border-radius:20px;
                                        background:@(tx.Status == "Success" ? "#e6f4d7" : "#fff8dc");
                                        color:@(tx.Status == "Success" ? "#4a7c2f" : "#b8860b");">
                                @tx.Status
                            </span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="text-align:center; padding:40px 0; color:#aaa;">
                    <div style="font-size:40px; margin-bottom:10px;">🧾</div>
                    <p style="margin:0; font-size:14px;">No transactions yet.</p>
                </div>
            }
        </div>

    </div>
</div>

@* @await Html.PartialAsync("_TopUpModal", new ELNET_FinalsProject.ViewModels.TopUpViewModel()) *@
<script>

    function previewProfileImage(event) {

        const image = document.getElementById("previewImage");

        image.src = URL.createObjectURL(event.target.files[0]);
    }
    
    function updateCartCount(added) {
        var el = document.getElementById('cart-count');
        if (el) {
            el.textContent = (parseInt(el.textContent) || 0) + added;
        }
    }

        function openTopUpModal() {
        document.getElementById('topUpOverlay').style.display = 'flex';
        document.body.style.overflow = 'hidden'; // Stop scrolling
    }

    function closeTopUpModal() {
        document.getElementById('topUpOverlay').style.display = 'none';
        document.body.style.overflow = ''; // Resume scrolling
    }

    function handleTopUpOverlayClick(e) {
        if (e.target === document.getElementById('topUpOverlay')) {
            closeTopUpModal();
        }
    }
    function openHistoryModal() {
        document.getElementById('historyOverlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeHistoryModal() {
        document.getElementById('historyOverlay').style.display = 'none';
        document.body.style.overflow = '';
    }

    function handleHistoryOverlayClick(e) {
        if (e.target === document.getElementById('historyOverlay')) {
            closeHistoryModal();
        }
    }
</script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}