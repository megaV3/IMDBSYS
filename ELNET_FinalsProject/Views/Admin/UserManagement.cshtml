@model IEnumerable<IMDBSYS.ViewModels.Admin.UserManagementViewModel>

@{
    ViewData["Title"] = "User Base Controls";
}

<style>
    /* ========================================================
           UserManagement View - Standalone Isolation Matrix
           ======================================================== */

    /* 1. FORCE VIEW COMPONENT ISOLATION CONTROLS */
    .users-isolated-wrapper {
        display: block !important;
        width: 100% !important;
        max-width: 100% !important;
        contain: inline-size !important; /* Mathematically freezes internal elements from altering outer layout dimensions */
        box-sizing: border-box !important;
    }

        /* 2. Lock down Bootstrap grid structures to prevent negative margin bleeding */
        .users-isolated-wrapper .row {
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            display: flex !important;
            flex-wrap: wrap !important;
        }

        /* 3. Force card boundary limits */
        .users-isolated-wrapper .card {
            width: 100% !important;
            max-width: 100% !important;
            box-sizing: border-box !important;
            transform: none !important;
            transition: none !important;
        }

        /* 4. Complete structural lockdown on badge sizes on hover (System Access Role) */
        .users-isolated-wrapper .table-hover tbody tr:hover td .badge,
        .users-isolated-wrapper .table-hover tbody tr td .badge {
            display: inline-block !important;
            width: 90px !important;
            max-width: 90px !important;
            min-width: 90px !important;
            text-align: center !important;
            letter-spacing: normal !important;
            transform: none !important;
        }

        /* 5. Freeze custom dual-action buttons to prevent spacing mutations on hover */
        .users-isolated-wrapper .table-hover tbody tr:hover td .btn,
        .users-isolated-wrapper .table-hover tbody tr td .btn {
            letter-spacing: normal !important;
            transition: none !important;
        }

        /* 6. Keep all user data cells locked into a strict uniform footprint */
        .users-isolated-wrapper .table-hover tbody tr:hover td,
        .users-isolated-wrapper .table-hover tbody tr td {
            height: 65px !important;
            max-height: 65px !important;
            min-height: 65px !important;
            vertical-align: middle !important;
            transition: none !important;
            white-space: nowrap !important;
        }
</style>

<div class="users-isolated-wrapper">
    <div class="row">
        <div class="col-12">

            <div class="card shadow-sm border-0 mt-3">
                <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="m-0 fw-bold text-dark">👥 Registered Access Management</h5>
                        <p class="text-muted small mb-0">Configure authentication claims, account states, and personnel assignment scopes</p>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID Key</th>
                                    <th>Full System Name</th>
                                    <th>Electronic Mail Address</th>
                                    <th>System Access Role</th>
                                    <th class="text-end px-4">Administrative Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var user in Model)
                                    {
                                        <tr>
                                            <td><code>USR-@user.Id.ToString("D4")</code></td>
                                            <td class="fw-bold text-dark">@user.FirstName @user.LastName</td>
                                            <td>@user.Email</td>
                                            <td>
                                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">
                                                    @user.Role
                                                </span>
                                            </td>
                                            <td class="text-end px-4">
                                                <div class="btn-group btn-group-sm">
                                                    <a asp-action="ModifyRole" asp-route-id="@user.Id" class="btn btn-outline-warning">Alter Role</a>
                                                    <a asp-action="BanToggle" asp-route-id="@user.Id" class="btn btn-outline-danger">Suspend</a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">Database contains no authenticated users.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>