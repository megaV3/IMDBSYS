@model IEnumerable<IMDBSYS.ViewModels.Admin.UserManagementViewModel>

@{
    ViewData["Title"] = "User Base Controls";
}

<style>
    /* ========================================================
           UserManagement View - Standalone Isolation Matrix
           ======================================================== */

    /* 1. FORCE VIEW COMPONENT ISOLATION CONTROLS */
    .users-isolated-wrapper {
        display: block !important;
        width: 100% !important;
        max-width: 100% !important;
        contain: inline-size !important;
        box-sizing: border-box !important;
    }

        /* 2. Lock down Bootstrap grid structures to prevent negative margin bleeding */
        .users-isolated-wrapper .row {
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            display: flex !important;
            flex-wrap: wrap !important;
        }

        /* 3. Force card boundary limits */
        .users-isolated-wrapper .card {
            width: 100% !important;
            max-width: 100% !important;
            box-sizing: border-box !important;
            transform: none !important;
            transition: none !important;
        }

        /* 4. Complete structural lockdown on badge sizes on hover (System Access Role) */
        .users-isolated-wrapper .table-hover tbody tr:hover td .badge,
        .users-isolated-wrapper .table-hover tbody tr td .badge {
            display: inline-block !important;
            width: 90px !important;
            max-width: 90px !important;
            min-width: 90px !important;
            text-align: center !important;
            letter-spacing: normal !important;
            transform: none !important;
        }

        /* 5. Freeze custom dual-action buttons to prevent spacing mutations on hover */
        .users-isolated-wrapper .table-hover tbody tr:hover td .btn,
        .users-isolated-wrapper .table-hover tbody tr td .btn {
            letter-spacing: normal !important;
            transition: none !important;
        }

        /* 6. Keep all user data cells locked into a strict uniform footprint */
        .users-isolated-wrapper .table-hover tbody tr:hover td,
        .users-isolated-wrapper .table-hover tbody tr td {
            height: 65px !important;
            max-height: 65px !important;
            min-height: 65px !important;
            vertical-align: middle !important;
            transition: none !important;
            white-space: nowrap !important;
        }
</style>

<div class="users-isolated-wrapper">
    <div class="row">
        <div class="col-12">

            <div class="card shadow-sm border-0 mt-3">
                <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="m-0 fw-bold text-dark">👥 Registered Access Management</h5>
                        <p class="text-muted small mb-0">Configure authentication claims, account states, and personnel assignment scopes</p>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID Key</th>
                                    <th>Full System Name</th>
                                    <th>Electronic Mail Address</th>
                                    <th>System Access Role</th>
                                    <th class="text-end px-4">Administrative Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var user in Model)
                                    {
                                        <tr>
                                            <td><code>USR-@user.Id.ToString("D4")</code></td>
                                            <td class="fw-bold text-dark">@user.FirstName @user.LastName</td>
                                            <td>@user.Email</td>
                                            <td>
                                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">
                                                    @user.Role
                                                </span>
                                            </td>
                                            <td class="text-end px-4">
                                                <div class="btn-group btn-group-sm">
                                                    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editUserModal-@user.Id">
                                                        Edit
                                                    </button>
                                                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteUserModal-@user.Id">
                                                        Remove
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">Database contains no authenticated users.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@if (Model != null && Model.Any())
{
    foreach (var user in Model)
    {
        <div class="modal fade" id="editUserModal-@user.Id" tabindex="-1" aria-labelledby="editUserModalLabel-@user.Id" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-light">
                        <h5 class="modal-title fw-bold text-dark" id="editUserModalLabel-@user.Id">✏️ Edit System Access: USR-@user.Id.ToString("D4")</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-action="EditUserRole" method="post">
                        <div class="modal-body text-start" style="white-space: normal;">
                            <input type="hidden" name="Id" value="@user.Id" />

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Account Identity Name</label>
                                <input type="text" class="form-control bg-light" value="@user.FirstName @user.LastName" readonly />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Electronic Mail Endpoint</label>
                                <input type="text" class="form-control bg-light" value="@user.Email" readonly />
                            </div>

                            <div class="mb-2">
                                <label class="form-label fw-bold small text-primary">Assigned System Security Role</label>
                                <select name="Role" class="form-select fw-bold text-dark" required>
                                    <option value="User" selected="@(user.Role == "User")">👤 Regular System User</option>
                                    <option value="Admin" selected="@(user.Role == "Admin")">🛠️ Administrative Supervisor</option>
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer bg-light border-top-0">
                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary btn-sm px-3">Update Access Rules</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade" id="deleteUserModal-@user.Id" tabindex="-1" aria-labelledby="deleteUserModalLabel-@user.Id" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title fw-bold" id="deleteUserModalLabel-@user.Id">⚠️ Confirm Account Removal</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-action="DeleteUser" method="post">
                        <div class="modal-body text-start" style="white-space: normal;">
                            <input type="hidden" name="Id" value="@user.Id" />
                            
                            <p class="text-dark mb-2">
                                You are about to permanently delete the following account from the system identity pool:
                            </p>
                            <div class="p-3 bg-light rounded border border-danger-subtle mb-3">
                                <strong class="d-block text-danger">@user.FirstName @user.LastName</strong>
                                <span class="small text-muted">@user.Email</span>
                                <span class="badge bg-secondary d-block mt-2" style="width: fit-content !important; min-width: 0 !important;">Role: @user.Role</span>
                            </div>
                            <p class="text-danger small fw-bold mb-0">
                                🚨 Warning: This action cannot be undone. All active application profiles matching this security credential instance will immediately terminate.
                            </p>
                        </div>
                        <div class="modal-footer bg-light border-top-0">
                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-danger btn-sm px-3">Permanently Remove User</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}