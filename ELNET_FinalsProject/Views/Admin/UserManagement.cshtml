@model IEnumerable<IMDBSYS.ViewModels.Admin.UserManagementViewModel> // Standard baseline placeholder model structure

@{
    ViewData["Title"] = "User Base Controls";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
        <div>
            <h5 class="m-0 fw-bold text-dark">👥 Registered Access Management</h5>
            <p class="text-muted small mb-0">Configure authentication claims, account states, and personnel assignment scopes</p>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID Key</th>
                        <th>Full System Name</th>
                        <th>Electronic Mail Address</th>
                        <th>System Access Role</th>
                        <th class="text-end px-4">Administrative Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td><code>USR-@user.Id.ToString("D4")</code></td>
                                <td class="fw-bold text-dark">@user.FirstName @user.LastName</td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">
                                        @user.Role
                                    </span>
                                </td>
                                <td class="text-end px-4">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="ModifyRole" asp-route-id="@user.Id" class="btn btn-outline-warning">Alter Role</a>
                                        <a asp-action="BanToggle" asp-route-id="@user.Id" class="btn btn-outline-danger">Suspend</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">Database contains no authenticated users.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>