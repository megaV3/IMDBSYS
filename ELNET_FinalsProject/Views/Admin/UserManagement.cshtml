@model IEnumerable<IMDBSYS.ViewModels.Admin.UserManagementViewModel>

@{
    ViewData["Title"] = "User Management";
}

<div class="page-header">
    <div>
        <h1>User Management</h1>
        <p>Configure roles, account states, and access permissions</p>
    </div>
</div>

<div class="pkcard">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table pk-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Full Name</th>
                        <th>Email Address</th>
                        <th>Role</th>
                        <th class="text-end" style="padding-right:22px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <span style="font-family:monospace; font-size:12px; color:#94a3b8;">
                                        USR-@user.Id.ToString("D4")
                                    </span>
                                </td>
                                <td style="font-weight:700; color:#1e293b;">
                                    @user.FirstName @user.LastName
                                </td>
                                <td style="color:#64748b;">@user.Email</td>
                                <td>
                                    <span class="pk-badge @(user.Role == "Admin" ? "pk-badge-danger" : "pk-badge-navy")">
                                        @user.Role
                                    </span>
                                </td>
                                <td class="text-end" style="padding-right:18px;">
                                    <div class="d-flex justify-content-end gap-2">
                                        <button type="button"
                                                class="pk-btn pk-btn-outline pk-btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editUserModal-@user.Id">
                                            Edit
                                        </button>
                                        <button type="button"
                                                class="pk-btn pk-btn-danger pk-btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#deleteUserModal-@user.Id">
                                            Remove
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5" style="color:#94a3b8;">
                                No registered users found in the system.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ── MODALS ── -->
@if (Model != null && Model.Any())
{
    foreach (var user in Model)
    {
        <!-- Edit Role Modal -->
        <div class="modal fade pk-modal" id="editUserModal-@user.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Access — USR-@user.Id.ToString("D4")</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="EditUserRole" method="post">
                        <div class="modal-body" style="white-space:normal;">
                            <input type="hidden" name="Id" value="@user.Id" />

                            <div class="mb-3">
                                <label style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Full Name</label>
                                <input type="text" class="pk-input form-control" value="@user.FirstName @user.LastName" readonly />
                            </div>

                            <div class="mb-3">
                                <label style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Email Address</label>
                                <input type="text" class="pk-input form-control" value="@user.Email" readonly />
                            </div>

                            <div>
                                <label style="font-size:11px; font-weight:700; color:#2D3A8C; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Assigned Role</label>
                                <select name="Role" class="pk-input form-select" required>
                                    <option value="User" selected="@(user.Role == "User")">RegularvUser</option>
                                    <option value="Admin" selected="@(user.Role == "Admin")">Administrative</option>
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="pk-btn pk-btn-outline pk-btn-sm" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="pk-btn pk-btn-primary pk-btn-sm">Update Role</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Delete Confirmation Modal -->
        <div class="modal fade pk-modal" id="deleteUserModal-@user.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <!-- Red header for destructive action -->
                    <div class="modal-header danger">
                        <h5 class="modal-title">Confirm Account Removal</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="DeleteUser" method="post">
                        <div class="modal-body" style="white-space:normal;">
                            <input type="hidden" name="Id" value="@user.Id" />

                            <p style="font-size:13.5px; color:#1e293b; margin-bottom:14px;">
                                You are about to permanently delete this account from the system:
                            </p>

                            <!-- User identity card -->
                            <div style="background:#fff5f5; border:1.5px solid #fecaca; border-radius:14px; padding:16px 18px; margin-bottom:16px;">
                                <div style="font-weight:700; color:#dc2626; font-size:14px; margin-bottom:3px;">
                                    @user.FirstName @user.LastName
                                </div>
                                <div style="font-size:12.5px; color:#64748b; margin-bottom:8px;">@user.Email</div>
                                <span class="pk-badge pk-badge-slate">Role: @user.Role</span>
                            </div>

                            <p style="font-size:12px; color:#dc2626; font-weight:700; margin:0;">
                                Warning: This action cannot be undone. All sessions and data tied to this account will be permanently removed.
                            </p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="pk-btn pk-btn-outline pk-btn-sm" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="pk-btn pk-btn-danger pk-btn-sm">Remove Permanently</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}