@model IEnumerable<IMDBSYS.Models.Order>

@{
    ViewData["Title"] = "Order Registry";
}

<style>
    /* ========================================================
           OrderRegistry View - Standalone Isolation Matrix
           ======================================================== */

    /* 1. FORCE COMPONENT ISOLATION CONTROLS */
    .order-registry-isolated-wrapper {
        display: block !important;
        width: 100% !important;
        max-width: 100% !important;
        contain: inline-size !important; /* Mathematically blocks internal elements from stretching container widths */
        box-sizing: border-box !important;
    }

        /* 2. Freeze outer rows from structural expansion */
        .order-registry-isolated-wrapper .row {
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            display: flex !important;
            flex-wrap: wrap !important;
        }

        /* 3. Force card boundary limits */
        .order-registry-isolated-wrapper .card {
            width: 100% !important;
            max-width: 100% !important;
            box-sizing: border-box !important;
            transform: none !important;
            transition: none !important;
        }

        /* 4. Complete structural lockdown on badge sizes on hover */
        .order-registry-isolated-wrapper .table-hover tbody tr:hover td .badge,
        .order-registry-isolated-wrapper .table-hover tbody tr td .badge {
            display: inline-block !important;
            width: 140px !important;
            max-width: 140px !important;
            min-width: 140px !important;
            text-align: center !important;
            letter-spacing: normal !important;
            transform: none !important;
        }

        /* 5. Freeze review buttons to stop micro padding updates on hover */
        .order-registry-isolated-wrapper .table-hover tbody tr:hover td .btn,
        .order-registry-isolated-wrapper .table-hover tbody tr td .btn {
            width: 150px !important;
            max-width: 150px !important;
            min-width: 150px !important;
            display: inline-block !important;
            letter-spacing: normal !important;
            transition: none !important;
        }

        /* 6. Keep all data grid cells locked into a strict uniform layout footprint */
        .order-registry-isolated-wrapper .table-hover tbody tr:hover td,
        .order-registry-isolated-wrapper .table-hover tbody tr td {
            height: 65px !important;
            max-height: 65px !important;
            min-height: 65px !important;
            vertical-align: middle !important;
            transition: none !important;
            white-space: nowrap !important;
        }
</style>

<div class="order-registry-isolated-wrapper">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0 mt-3">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="m-0 fw-bold text-dark">🛒 Global Order Registry</h5>
                    <p class="text-muted small mb-0">Audit security trail logs, structural system sales, and purchase accountability</p>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Order ID</th>
                                    <th>User Security ID</th>
                                    <th>Customer / Client Name</th>
                                    <th>Timestamp Registered</th>
                                    <th>Gross Value</th>
                                    <th>System State</th>
                                    <th class="text-end px-4">Audit Trace</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var order in Model)
                                    {
                                        <tr>
                                            <td><strong>#@order.OrderId</strong></td>
                                            <td><code>USR-@order.UserId.ToString("D4")</code></td>
                                            <td class="fw-bold">@order.CustomerName</td>
                                            <td class="text-muted">@order.OrderDate.ToString("yyyy-MM-dd hh:mm tt")</td>
                                            <td class="text-dark fw-bold">₱@order.TotalAmount.ToString("N2")</td>
                                            <td>
                                                <span class="badge @(order.IsCompleted ? "bg-success" : "bg-warning text-dark")">
                                                    @(order.IsCompleted ? "Settled & Fulfilled" : "Open / Pending")
                                                </span>
                                            </td>
                                            <td class="text-end px-4">
                                                <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-light border text-dark">
                                                    Review Items (@(order.OrderItems?.Count ?? 0))
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-5 text-muted">No historical transactions populated yet.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>