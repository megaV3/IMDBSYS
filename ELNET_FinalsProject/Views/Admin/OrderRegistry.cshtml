@model IEnumerable<IMDBSYS.Models.Order>

@{
    ViewData["Title"] = "Order Registry";
}

<style>

    .registry-filter-input,
    .registry-filter-select {
        height: 46px !important;
        border-radius: 12px !important;
        border: 1px solid #dbe2ea !important;
        font-size: 15px;
        color: #1e293b;
        box-shadow: none !important;
        transition: all 0.2s ease;
    }

        .registry-filter-input:focus,
        .registry-filter-select:focus {
            border-color: #4f46e5 !important;
            box-shadow: 0 0 0 3px rgba(79,70,229,0.12) !important;
        }

    .registry-filter-input {
        padding-left: 16px !important;
        padding-right: 38px !important;
    }

    .registry-clear-btn {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #94a3b8;
        font-size: 18px;
        font-weight: 700;
        transition: 0.2s ease;
        user-select: none;
    }

        .registry-clear-btn:hover {
            color: #475569;
        }

</style>

<div class="page-header">
    <div>
        <h1>Order Registry</h1>
        <p>Audit trail for all sales transactions</p>
    </div>
</div>

<div class="pkcard">

    <!-- SEARCH + FILTER -->
    <div class="card-body border-bottom" style="padding:18px;">

        <div class="row g-3">

            <!-- Search -->
            <div class="col-md-5">

                <div style="position:relative;">

                    <input type="text"
                           id="orderSearchInput"
                           class="form-control registry-filter-input"
                           placeholder="Search order ID, customer, or user..."
                           onkeyup="filterOrders()" />

                    <!-- Clear -->
                    <span class="registry-clear-btn"
                          onclick="clearSearch()">
                        ×
                    </span>

                </div>

            </div>

            <!-- Status Filter -->
            <div class="col-md-3">

                <select id="statusFilter"
                        class="form-select registry-filter-select"
                        onchange="filterOrders()">

                    <option value="">All Status</option>
                    <option value="Completed">Completed</option>
                    <option value="Pending">Pending</option>

                </select>

            </div>

        </div>

    </div>

    <!-- TABLE -->
    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table pk-table text-center">

                <thead>
                    <tr>
                        <th class="text-start">Order ID</th>
                        <th>User ID</th>
                        <th class="text-start">Customer</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody id="orderTableBody">

                    @if (Model != null && Model.Any())
                    {
                        foreach (var order in Model)
                        {
                            <tr class="order-row"
                                data-orderid="@order.OrderId"
                                data-customer="@order.CustomerName.ToLower()"
                                data-user="USR-@order.UserId.ToString("D4")"
                                data-status="@(order.IsCompleted ? "Completed" : "Pending")">

                                <!-- Order ID -->
                                <td class="text-start">

                                    <span style="
                                                    font-weight:700;
                                                    color:#2D3A8C;">

                                        #@order.OrderId

                                    </span>

                                </td>

                                <!-- User -->
                                <td>

                                    <span style="
                                                    font-family:monospace;
                                                    font-size:11.5px;
                                                    color:#ef4444;">

                                        USR-@order.UserId.ToString("D4")

                                    </span>

                                </td>

                                <!-- Customer -->
                                <td class="text-start"
                                    style="
                                                font-weight:700;
                                                color:#1e293b;">

                                    @order.CustomerName

                                </td>

                                <!-- Date -->
                                <td style="
                                                color:#64748b;
                                                font-size:12.5px;">

                                    @order.OrderDate.ToString("yyyy-MM-dd hh:mm tt")

                                </td>

                                <!-- Total -->
                                <td style="font-weight:700;">

                                    ₱@order.TotalAmount.ToString("N2")

                                </td>

                                <!-- Status -->
                                <td>

                                    @if (order.IsCompleted)
                                    {
                                        <span class="pk-badge pk-badge-success">
                                            Completed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="pk-badge pk-badge-warning">
                                            Pending
                                        </span>
                                    }

                                </td>

                                <!-- Actions -->
                                <td>

                                    <div class="d-flex justify-content-center gap-2">

                                        <button type="button"
                                                class="pk-btn pk-btn-sm"
                                                style="
                                                            background:#f0f2f8;
                                                            color:#2D3A8C;
                                                            border:1.5px solid #c7cde8;"
                                                data-bs-toggle="modal"
                                                data-bs-target="#reviewItemsModal-@order.OrderId">

                                            Items (@(order.OrderItems?.Count ?? 0))

                                        </button>

                                    </div>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="7"
                                class="text-center py-5"
                                style="color:#94a3b8;">

                                No transactions recorded in the order registry.

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

            <!-- EMPTY STATE -->
            <div id="noOrderResults"
                 style="
                    display:none;
                    text-align:center;
                    padding:40px;
                    color:#94a3b8;">

                No matching orders found

            </div>

        </div>

    </div>

</div>

<!-- MODALS -->
@if (Model != null && Model.Any())
{
    foreach (var order in Model)
    {
        <div class="modal fade pk-modal"
             id="reviewItemsModal-@order.OrderId"
             tabindex="-1"
             aria-hidden="true">

            <div class="modal-dialog modal-dialog-centered modal-lg">

                <div class="modal-content">

                    <div class="modal-header">

                        <h5 class="modal-title">
                            Order Breakdown — #@order.OrderId
                        </h5>

                        <button type="button"
                                class="btn-close btn-close-white"
                                data-bs-dismiss="modal">
                        </button>

                    </div>

                    <div class="modal-body p-0">

                        <div style="
                                        background:#f8f9ff;
                                        padding:16px 24px;
                                        border-bottom:1px solid #eef0f7;
                                        display:flex;
                                        justify-content:space-between;">

                            <div>

                                <div style="
                                                font-size:11px;
                                                color:#94a3b8;">

                                    Customer

                                </div>

                                <div style="font-weight:700;">

                                    @order.CustomerName

                                </div>

                            </div>

                            <div class="text-end">

                                <div style="
                                                font-size:11px;
                                                color:#94a3b8;">

                                    Order Date

                                </div>

                                <div style="font-weight:700;">

                                    @order.OrderDate.ToString("yyyy-MM-dd hh:mm tt")

                                </div>

                            </div>

                        </div>

                        <div class="table-responsive">

                            <table class="table pk-table text-center">

                                <thead>
                                    <tr>
                                        <th class="text-start ps-4">Product</th>
                                        <th>Variant</th>
                                        <th>Unit Price</th>
                                        <th>Qty</th>
                                        <th class="text-end pe-4">Subtotal</th>
                                    </tr>
                                </thead>

                                <tbody>

                                    @if (order.OrderItems != null && order.OrderItems.Any())
                                    {
                                        foreach (var item in order.OrderItems)
                                        {
                                            <tr>

                                                <td class="text-start ps-4">

                                                    <div style="font-weight:700;">

                                                        @(item.Menu?.Name ?? "Unknown Item")

                                                    </div>

                                                </td>

                                                <td>

                                                    <span class="pk-badge pk-badge-slate">

                                                        @(item.Variation ?? "Standard")

                                                    </span>

                                                </td>

                                                <td>

                                                    ₱@item.Price.ToString("N2")

                                                </td>

                                                <td>

                                                    × @item.Quantity

                                                </td>

                                                <td class="text-end pe-4"
                                                    style="font-weight:700;">

                                                    ₱@((item.Price * item.Quantity).ToString("N2"))

                                                </td>

                                            </tr>
                                        }
                                    }

                                </tbody>

                            </table>

                        </div>

                        <div style="
                                        background:#f8f9ff;
                                        padding:16px 24px;
                                        display:flex;
                                        justify-content:space-between;">

                            <span style="font-weight:700;">
                                Total
                            </span>

                            <span style="
                                            font-size:20px;
                                            font-weight:800;
                                            color:#15803d;">

                                ₱@order.TotalAmount.ToString("N2")

                            </span>

                        </div>

                    </div>

                    <div class="modal-footer">

                        <button type="button"
                                class="pk-btn pk-btn-outline pk-btn-sm"
                                data-bs-dismiss="modal">

                            Close

                        </button>

                    </div>

                </div>

            </div>

        </div>
    }
}

@section Scripts {

    <script>

        function filterOrders() {

            let search =
                document.getElementById("orderSearchInput")
                .value
                .toLowerCase();

            let status =
                document.getElementById("statusFilter")
                .value;

            let rows =
                document.querySelectorAll(".order-row");

            let visible = 0;

            rows.forEach(row => {

                let id =
                    row.dataset.orderid.toLowerCase();

                let customer =
                    row.dataset.customer.toLowerCase();

                let user =
                    row.dataset.user.toLowerCase();

                let rowStatus =
                    row.dataset.status;

                let matchesSearch =
                    id.includes(search) ||
                    customer.includes(search) ||
                    user.includes(search);

                let matchesStatus =
                    status === "" ||
                    rowStatus === status;

                if (matchesSearch && matchesStatus) {

                    row.style.display = "";
                    visible++;

                }
                else {

                    row.style.display = "none";
                }

            });

            document.getElementById("noOrderResults").style.display =
                visible === 0 ? "block" : "none";
        }

        function clearSearch() {

            document.getElementById("orderSearchInput").value = "";

            filterOrders();
        }

    </script>

}