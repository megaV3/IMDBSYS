@model IEnumerable<IMDBSYS.Models.Order>

@{
    ViewData["Title"] = "Order Registry";
}

<div class="page-header">
    <div>
        <h1>Order Registry</h1>
        <p>Audit trail for all sales transactions</p>
    </div>
</div>

<div class="pkcard">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table pk-table text-center">
                <thead>
                    <tr>
                        <th class="text-start">Order ID</th>
                        <th>User ID</th>
                        <th class="text-start">Customer</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var order in Model)
                        {
                            <tr>
                                <td class="text-start"><span style="font-weight:700; color:#2D3A8C;">#@order.OrderId</span></td>
                                <td><span style="font-family:monospace; font-size:11.5px; color:#ef4444;">USR-@order.UserId.ToString("D4")</span></td>
                                <td class="text-start" style="font-weight:700; color:#1e293b;">@order.CustomerName</td>
                                <td style="color:#64748b; font-size:12.5px;">@order.OrderDate.ToString("yyyy-MM-dd hh:mm tt")</td>
                                <td style="font-weight:700;">₱@order.TotalAmount.ToString("N2")</td>
                                <td>
                                    @if (order.IsCompleted)
                                    {
                                        <span class="pk-badge pk-badge-success">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="pk-badge pk-badge-warning">Pending</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">
                                        <button type="button"
                                                class="pk-btn pk-btn-sm"
                                                style="background:#f0f2f8; color:#2D3A8C; border:1.5px solid #c7cde8;"
                                                data-bs-toggle="modal" data-bs-target="#reviewItemsModal-@order.OrderId">
                                            Items (@(order.OrderItems?.Count ?? 0))
                                        </button>
                                        @if (!order.IsCompleted)
                                        {
                                            <form asp-action="CompleteOrder" method="post" class="m-0">
                                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                                <button type="submit" class="pk-btn pk-btn-primary pk-btn-sm">
                                                    Complete
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center py-5" style="color:#94a3b8;">No transactions recorded in the order registry.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Order Item Modals -->
@if (Model != null && Model.Any())
{
    foreach (var order in Model)
    {
        <div class="modal fade pk-modal" id="reviewItemsModal-@order.OrderId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Order Breakdown — #@order.OrderId</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-0">
                        <!-- Order meta -->
                        <div style="background:#f8f9ff; padding:16px 24px; border-bottom:1px solid #eef0f7; display:flex; justify-content:space-between; align-items:center;">
                            <div>
                                <div style="font-size:11px; color:#94a3b8; margin-bottom:2px;">Customer</div>
                                <div style="font-weight:700; color:#1e293b;">@order.CustomerName</div>
                            </div>
                            <div class="text-end">
                                <div style="font-size:11px; color:#94a3b8; margin-bottom:2px;">Order Date</div>
                                <div style="font-weight:700; color:#1e293b;">@order.OrderDate.ToString("yyyy-MM-dd hh:mm tt")</div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table pk-table text-center">
                                <thead>
                                    <tr>
                                        <th class="text-start ps-4">Product</th>
                                        <th>Variant</th>
                                        <th>Unit Price</th>
                                        <th>Qty</th>
                                        <th class="text-end pe-4">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (order.OrderItems != null && order.OrderItems.Any())
                                    {
                                        foreach (var item in order.OrderItems)
                                        {
                                            <tr>
                                                <td class="text-start ps-4">
                                                    <div class="d-flex align-items-center gap-3">
                                                        <img src="@(string.IsNullOrEmpty(item.Menu?.ImagePath) ? "/images/profiles/default-picture.webp" : item.Menu.ImagePath)"
                                                             style="width:38px; height:38px; border-radius:10px; object-fit:cover; border:1px solid #e2e8f0;"
                                                             alt="Product" />
                                                        <div>
                                                            <div style="font-weight:700; color:#1e293b; font-size:13.5px;">@(item.Menu?.Name ?? "Unknown Item")</div>
                                                            <div style="font-size:11px; color:#94a3b8;">@(item.Menu?.Category ?? "N/A")</div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td><span class="pk-badge pk-badge-slate">@(item.Variation ?? "Standard")</span></td>
                                                <td>₱@item.Price.ToString("N2")</td>
                                                <td style="font-weight:700;">× @item.Quantity</td>
                                                <td class="text-end pe-4" style="font-weight:700; color:#2D3A8C;">
                                                    ₱@((item.Price * item.Quantity).ToString("N2"))
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="5" class="text-center py-4" style="color:#94a3b8;">No items found.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div style="background:#f8f9ff; padding:16px 24px; border-top:1px solid #eef0f7; display:flex; justify-content:space-between; align-items:center;">
                            <span style="font-size:12px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:0.6px;">Total Amount</span>
                            <span style="font-size:22px; font-weight:800; color:#15803d;">₱@order.TotalAmount.ToString("N2")</span>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="pk-btn pk-btn-outline pk-btn-sm" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
}