@model IEnumerable<IMDBSYS.Models.Order>

@{
    ViewData["Title"] = "Order Registry";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 border-bottom">
        <h5 class="m-0 fw-bold text-dark">🛒 Global Order Registry</h5>
        <p class="text-muted small mb-0">Audit security trail logs, structural system sales, and purchase accountability</p>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Order ID</th>
                        <th>User Security ID</th>
                        <th>Customer / Client Name</th>
                        <th>Timestamp Registered</th>
                        <th>Gross Value</th>
                        <th>System State</th>
                        <th class="text-end px-4">Audit Trace</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>#@order.OrderId</strong></td>
                                <td><code>USR-@order.UserId.ToString("D4")</code></td>
                                <td class="fw-bold">@order.CustomerName</td>
                                <td class="text-muted">@order.OrderDate.ToString("yyyy-MM-dd hh:mm tt")</td>
                                <td class="text-dark fw-bold">₱@order.TotalAmount.ToString("N2")</td>
                                <td>
                                    <span class="badge @(order.IsCompleted ? "bg-success" : "bg-warning text-dark")">
                                        @(order.IsCompleted ? "Settled & Fulfilled" : "Open / Pending")
                                    </span>
                                </td>
                                <td class="text-end px-4">
                                    <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-light border text-dark">
                                        Review Items (@(order.OrderItems?.Count ?? 0))
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">No historical transactions populated yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>