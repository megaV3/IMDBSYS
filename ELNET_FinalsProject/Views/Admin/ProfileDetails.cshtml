@{
    ViewData["Title"] = "Administrative Profile";
    var profile = ViewBag.Profile;

    string fullName = profile?.FullName ?? "System Admin";
    string email    = profile?.Email ?? "admin@imdbsys.com";
    string role     = profile?.Role ?? "Admin";
    string status   = profile?.AccountStatus ?? "Active";
    string scope    = profile?.SecurityScope ?? "Global Read/Write/Delete Permissions";
    string picPath  = profile?.ProfilePicturePath ?? "/images/profiles/default-picture.webp";

    var nameParts = fullName.Split(' ');
    string fName = nameParts.Length > 0 ? nameParts[0] : "";
    string lName = nameParts.Length > 1 ? string.Join(" ", nameParts.Skip(1)) : "";
}

<div class="page-header">
    <div>
        <h1>Administrative Profile</h1>
        <p>Verified identity, access claims, and security scope</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-xl-6 col-lg-8">
        <div class="pkcard">

            <!-- Profile header -->
            <div style="background: linear-gradient(135deg, #2D3A8C, #1a2563); border-radius:18px 18px 0 0; padding:32px 28px; text-align:center;">
                <div style="margin-bottom:16px;">
                    @if (!string.IsNullOrEmpty(picPath) && !picPath.Contains("default-picture.webp") && System.IO.File.Exists(System.IO.Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", picPath.TrimStart('/'))))
                    {
                        <img src="@picPath?v=@DateTime.Now.Ticks"
                             style="width:90px; height:90px; border-radius:50%; object-fit:cover; border:3px solid rgba(255,255,255,0.4); display:block; margin:0 auto;"
                             alt="Admin Profile Photo" />
                    }
                    else
                    {
                        <div style="width:90px; height:90px; border-radius:50%; background:rgba(255,255,255,0.18); border:3px solid rgba(255,255,255,0.3); display:flex; align-items:center; justify-content:center; font-size:28px; font-weight:800; color:#fff; margin:0 auto;">
                            AD
                        </div>
                    }
                </div>
                <div style="font-size:20px; font-weight:800; color:#fff; margin-bottom:4px;">@fullName</div>
                <div style="font-size:12px; color:rgba(255,255,255,0.6);">@email</div>
                <div style="margin-top:14px;">
                    <button type="button"
                            style="background:rgba(255,255,255,0.2); border:1.5px solid rgba(255,255,255,0.35); color:#fff; border-radius:50px; padding:7px 20px; font-size:12.5px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; transition:background 0.15s;"
                            data-bs-toggle="modal" data-bs-target="#editAdminProfileModal">
                        Edit Profile
                    </button>
                </div>
            </div>

            <!-- Profile body -->
            <div class="card-body" style="padding:26px 28px;">

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label style="font-size:11px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Full Name</label>
                        <input type="text" class="pk-input form-control" value="@fullName" readonly />
                    </div>
                    <div class="col-6">
                        <label style="font-size:11px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Email Address</label>
                        <input type="text" class="pk-input form-control" value="@email" readonly />
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label style="font-size:11px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Access Level</label>
                        <div style="padding-top:4px;">
                            <span class="pk-badge pk-badge-danger" style="font-size:13px; padding:6px 16px;">@role</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <label style="font-size:11px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Account Status</label>
                        <div style="padding-top:4px;">
                            <span class="pk-badge pk-badge-success" style="font-size:13px; padding:6px 16px;">@status</span>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label style="font-size:11px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Security Clearance Scope</label>
                    <input type="text" class="pk-input form-control" style="font-family:monospace; font-size:12.5px;" value="@scope" readonly />
                </div>

                <div class="d-flex justify-content-end">
                    <a asp-action="Dashboard" class="pk-btn pk-btn-outline pk-btn-sm">Back to Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Profile Modal -->
<div class="modal fade pk-modal" id="editAdminProfileModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Profile</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form asp-action="ProfileDetails" method="post" enctype="multipart/form-data">
                <div class="modal-body text-center" style="padding:28px 26px;">

                    <!-- Avatar upload area -->
                    <div style="position:relative; width:90px; height:90px; margin:0 auto 8px; cursor:pointer;"
                         onclick="document.getElementById('fileUploadInput').click();">

                        @if (!string.IsNullOrEmpty(picPath) && !picPath.Contains("default-picture.webp") && System.IO.File.Exists(System.IO.Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", picPath.TrimStart('/'))))
                        {
                            <img id="modalAvatarPreview" src="@picPath?v=@DateTime.Now.Ticks"
                                 style="width:90px; height:90px; border-radius:50%; object-fit:cover; border:3px solid #2D3A8C;"
                                 alt="Preview" />
                        }
                        else
                        {
                            <div id="modalAvatarText"
                                 style="width:90px; height:90px; border-radius:50%; background:linear-gradient(135deg,#2D3A8C,#1a2563); border:3px solid #2D3A8C; display:flex; align-items:center; justify-content:center; font-size:26px; font-weight:800; color:#fff;">
                                AD
                            </div>
                        }

                        <div style="position:absolute; bottom:2px; right:2px; background:#1e293b; color:#fff; width:26px; height:26px; border-radius:50%; border:2px solid #fff; display:flex; align-items:center; justify-content:center; font-size:11px;">
                            +
                        </div>
                    </div>
                    <p style="font-size:11.5px; color:#94a3b8; margin-bottom:22px;">Click to change photo</p>

                    <input type="file" id="fileUploadInput" name="profilePicture" class="d-none" accept="image/*" />

                    <div class="text-start mb-3">
                        <label style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">First Name</label>
                        <input type="text" name="firstName" class="pk-input form-control" value="@fName" required />
                    </div>

                    <div class="text-start mb-3">
                        <label style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Last Name</label>
                        <input type="text" name="lastName" class="pk-input form-control" value="@lName" required />
                    </div>

                    <div class="text-start">
                        <label style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Email Address</label>
                        <input type="email" class="pk-input form-control" value="@email" readonly />
                        <div style="font-size:11px; color:#94a3b8; margin-top:5px;">Email cannot be changed.</div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="pk-btn pk-btn-outline pk-btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="pk-btn pk-btn-primary pk-btn-sm">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    /* Avatar preview — logic preserved */
    document.getElementById('fileUploadInput').addEventListener('change', function (e) {
        if (e.target.files && e.target.files[0]) {
            const reader = new FileReader();
            reader.onload = function (event) {
                const imgEl  = document.getElementById('modalAvatarPreview');
                const textEl = document.getElementById('modalAvatarText');
                if (imgEl) {
                    imgEl.src = event.target.result;
                } else if (textEl) {
                    const newImg = document.createElement('img');
                    newImg.id = 'modalAvatarPreview';
                    newImg.src = event.target.result;
                    newImg.style = 'width:90px;height:90px;border-radius:50%;object-fit:cover;border:3px solid #2D3A8C;';
                    textEl.parentNode.replaceChild(newImg, textEl);
                }
            };
            reader.readAsDataURL(e.target.files[0]);
        }
    });
</script>