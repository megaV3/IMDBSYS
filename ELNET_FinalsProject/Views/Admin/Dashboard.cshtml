@model IMDBSYS.ViewModels.Admin.DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 text-dark">Admin Dashboard</h1>
        <span class="text-muted">Last updated: @DateTime.Now.ToString("g")</span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4 col-lg-2">
            <div class="card bg-primary text-white h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h6 class="card-title text-uppercase mb-1 opacity-75">Total Users</h6>
                    <h2 class="fw-bold m-0">@Model.TotalUsers</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-2">
            <div class="card bg-info text-white h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h6 class="card-title text-uppercase mb-1 opacity-75">Total Products</h6>
                    <h2 class="fw-bold m-0">@Model.TotalProducts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 col-lg-2">
            <div class="card bg-success text-white h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h6 class="card-title text-uppercase mb-1 opacity-75">Total Orders</h6>
                    <h2 class="fw-bold m-0">@Model.TotalOrders</h2>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card bg-dark text-white h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h6 class="card-title text-uppercase mb-1 opacity-75">Sales Revenue</h6>
                    <h2 class="fw-bold m-0">₱@Model.TotalSalesRevenue.ToString("N2")</h2>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card bg-secondary text-white h-100 shadow-sm">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h6 class="card-title text-uppercase mb-1 opacity-75">Total Top-Ups</h6>
                    <h2 class="fw-bold m-0">₱@Model.TotalTopUpAmount.ToString("N2")</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8">
            
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="m-0 font-weight-bold text-dark">Recent Orders</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Date</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentOrders.Any())
                                {
                                    foreach (var order in Model.RecentOrders)
                                    {
                                        <tr>
                                            <td><strong>#@order.OrderId</strong></td>
                                            <td>@order.CustomerName</td>
                                            <td>@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>₱@order.TotalAmount.ToString("N2")</td>
                                            <td>
                                                <span class="badge @(order.IsCompleted ? "bg-success" : "bg-warning text-dark")">
                                                    @(order.IsCompleted ? "Completed" : "Pending")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">No recent orders found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="m-0 font-weight-bold text-dark">Recent Top-Up Transactions</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Transaction ID</th>
                                    <th>User Email</th>
                                    <th>Payment Method</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentTopUps.Any())
                                {
                                    foreach (var topUp in Model.RecentTopUps)
                                    {
                                        <tr>
                                            <td>@topUp.TransactionId</td>
                                            <td>@topUp.Email</td>
                                            <td>@topUp.PaymentMethod</td>
                                            <td>₱@topUp.Amount.ToString("N2")</td>
                                            <td>@topUp.TransactionDate.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                <span class="badge @(topUp.Status == "Completed" || topUp.Status == "Approved" ? "bg-success" : "bg-danger")">
                                                    @topUp.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">No recent top-up requests.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>

        <div class="col-xl-4">
            
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="m-0 font-weight-bold text-dark">Inventory Summary</h5>
                </div>
                <div class="card-body text-center py-4">
                    <p class="text-muted mb-1 text-uppercase small font-weight-bold">Total Items in Stock</p>
                    <h1 class="display-4 fw-bold text-secondary">@Model.TotalStockQuantity</h1>
                </div>
            </div>

            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="m-0 font-weight-bold">⚠️ Low Stock Warnings</h5>
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @if (Model.LowStockProducts.Any())
                        {
                            foreach (var variant in Model.LowStockProducts)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-start py-3">
                                    <div class="ms-2 me-auto">
                                        <div class="fw-bold text-dark">@(variant.Menu?.Name ?? "Unknown Product")</div>
                                        <span class="text-muted small">Variant: @variant.VariantName</span>
                                    </div>
                                    <div class="text-end">
                                        <span class="badge bg-danger rounded-pill d-block mb-1">
                                            @variant.StockQuantity left
                                        </span>
                                        <span class="text-muted xs text-decoration-underline" style="font-size: 0.75rem;">
                                            Thresh: @variant.LowStockThreshold
                                        </span>
                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item py-4 text-center text-muted">
                                <i class="bi bi-check-circle text-success fs-4 d-block mb-2"></i> All products are sufficiently stocked!
                            </li>
                        }
                    </ul>
                </div>
            </div>

        </div>
    </div>
</div>