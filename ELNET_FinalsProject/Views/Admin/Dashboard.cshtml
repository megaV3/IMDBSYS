@model IMDBSYS.ViewModels.Admin.DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<!-- Page header -->
<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p>System overview and live telemetry</p>
    </div>
    <span style="font-size:12px; color:#64748b; background:#fff; border:1px solid #e2e8f0; border-radius:50px; padding:7px 16px; font-weight:600;">
        Synced: @DateTime.Now.ToString("MMM dd, yyyy  h:mm tt")
    </span>
</div>

<!-- Stat cards row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-auto" style="flex:1;">
        <div class="stat-card stat-navy">
            <div class="stat-label">Total Users</div>
            <div class="stat-value">@Model.TotalUsers</div>
        </div>
    </div>
    <div class="col-6 col-xl-auto" style="flex:1;">
        <div class="stat-card stat-indigo">
            <div class="stat-label">Total Products</div>
            <div class="stat-value">@Model.TotalProducts</div>
        </div>
    </div>
    <div class="col-6 col-xl-auto" style="flex:1;">
        <div class="stat-card stat-teal">
            <div class="stat-label">Total Orders</div>
            <div class="stat-value">@Model.TotalOrders</div>
        </div>
    </div>
    <div class="col-6 col-xl-auto" style="flex:1;">
        <div class="stat-card stat-slate">
            <div class="stat-label">Sales Revenue</div>
            <div class="stat-value" style="font-size:22px;">₱@Model.TotalSalesRevenue.ToString("N2")</div>
        </div>
    </div>
    <div class="col-6 col-xl-auto" style="flex:1;">
        <div class="stat-card stat-violet">
            <div class="stat-label">Total Top-Ups</div>
            <div class="stat-value" style="font-size:22px;">₱@Model.TotalTopUpAmount.ToString("N2")</div>
        </div>
    </div>
</div>

<!-- Main content grid -->
<div class="row g-4">

    <!-- Left column: tables -->
    <div class="col-xl-8">

        <!-- Recent Orders -->
        <div class="pkcard mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <div style="font-size:14px; font-weight:700; color:#1a2563;">Recent Orders</div>
                    <div style="font-size:12px; color:#64748b;">Latest customer transactions</div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table pk-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Date</th>
                                <th>Total</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentOrders.Any())
                            {
                                foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td><span style="font-weight:700; color:#2D3A8C;">#@order.OrderId</span></td>
                                        <td style="font-weight:600;">@order.CustomerName</td>
                                        <td style="color:#64748b;">@order.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td style="font-weight:700;">₱@order.TotalAmount.ToString("N2")</td>
                                        <td>
                                            <span class="pk-badge @(order.IsCompleted ? "pk-badge-success" : "pk-badge-warning")">
                                                @(order.IsCompleted ? "Completed" : "Pending")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="text-center py-4" style="color:#94a3b8;">No recent orders found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Recent Top-Ups -->
        <div class="pkcard mb-4">
            <div class="card-header">
                <div style="font-size:14px; font-weight:700; color:#1a2563;">Recent Top-Up Transactions</div>
                <div style="font-size:12px; color:#64748b;">Wallet deposits and payment records</div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table pk-table">
                        <thead>
                            <tr>
                                <th>Transaction ID</th>
                                <th>User Email</th>
                                <th>Method</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentTopUps.Any())
                            {
                                foreach (var topUp in Model.RecentTopUps)
                                {
                                    <tr>
                                        <td style="font-family:monospace; font-size:12px; color:#64748b;">@topUp.TransactionId</td>
                                        <td style="font-weight:600;">@topUp.Email</td>
                                        <td><span class="pk-badge pk-badge-slate">@topUp.PaymentMethod</span></td>
                                        <td style="font-weight:700; color:#15803d;">₱@topUp.Amount.ToString("N2")</td>
                                        <td>
                                            <span class="pk-badge @(topUp.Status == "Completed" || topUp.Status == "Approved" ? "pk-badge-success" : "pk-badge-danger")">
                                                @topUp.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="text-center py-4" style="color:#94a3b8;">No recent top-up requests.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Recent Stock Receipts -->
        <div class="pkcard mb-4">
            <div class="card-header">
                <div style="font-size:14px; font-weight:700; color:#1a2563;">Recent Product Stock Receipts</div>
                <div style="font-size:12px; color:#64748b;">Inbound inventory delivery logs</div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table pk-table text-center">
                        <thead>
                            <tr>
                                <th class="text-start">Log ID</th>
                                <th class="text-start">Product / Config</th>
                                <th>Intake Qty</th>
                                <th>Total Cost</th>
                                <th>Timestamp</th>
                                <th>Operator</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentStockChanges != null && Model.RecentStockChanges.Any())
                            {
                                foreach (var change in Model.RecentStockChanges)
                                {
                                    <tr>
                                        <td class="text-start">
                                            <span style="font-family:monospace; font-size:12px; color:#64748b;">#@change.DeliveryLogId</span>
                                        </td>
                                        <td class="text-start">
                                            <span style="font-weight:700; color:#1e293b;">@(change.MenuVariation?.Menu?.Name ?? "Unknown Item")</span>
                                            <span style="color:#94a3b8; font-size:11px; display:block;">@(change.MenuVariation?.VariantName ?? "N/A")</span>
                                        </td>
                                        <td>
                                            <span class="pk-badge pk-badge-teal">+@change.QuantityAdded units</span>
                                        </td>
                                        <td style="font-weight:700; color:#2D3A8C;">₱@change.TotalAmount.ToString("N2")</td>
                                        <td style="color:#64748b; font-size:12px;">@change.DeliveryDate.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>
                                            <span class="pk-badge pk-badge-slate">@change.ProcessedBy</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="6" class="text-center py-4" style="color:#94a3b8;">No recent stock replenishment batches recorded.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    <!-- Right column: inventory summary -->
    <div class="col-xl-4">

        <div class="pkcard mb-4">
            <div class="card-header">
                <div style="font-size:14px; font-weight:700; color:#1a2563;">Inventory Summary</div>
            </div>
            <div class="card-body text-center py-4">
                <p style="font-size:11px; font-weight:700; letter-spacing:0.8px; text-transform:uppercase; color:#94a3b8; margin-bottom:8px;">
                    Total Items in Stock
                </p>
                <div style="font-size:52px; font-weight:800; color:#2D3A8C; line-height:1;">
                    @Model.TotalStockQuantity
                </div>
                <div style="font-size:12px; color:#94a3b8; margin-top:6px;">units across all variants</div>
            </div>
        </div>

        <!-- Low Stock Warnings -->
        <div class="pkcard" style="border-top: 3px solid #ef4444; border-radius: 18px;">
            <div class="card-header">
                <div style="font-size:14px; font-weight:700; color:#dc2626;">Low Stock Alerts</div>
                <div style="font-size:12px; color:#64748b;">Items needing immediate restock</div>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush" style="border-radius:0 0 18px 18px; overflow:hidden;">
                    @if (Model.LowStockProducts.Any())
                    {
                        foreach (var variant in Model.LowStockProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3 px-4 border-0 border-bottom"
                                style="border-color:#f1f3f9 !important;">
                                <div>
                                    <div style="font-weight:700; font-size:13.5px; color:#1e293b;">
                                        @(variant.Menu?.Name ?? "Unknown Product")
                                    </div>
                                    <div style="font-size:11.5px; color:#94a3b8;">@variant.VariantName</div>
                                </div>
                                <span class="pk-badge pk-badge-danger">@variant.StockQuantity left</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-center py-4 border-0" style="color:#94a3b8; font-size:13px;">
                            All products are sufficiently stocked.
                        </li>
                    }
                </ul>
            </div>
        </div>

    </div>
</div>