@model IEnumerable<IMDBSYS.Models.MenuVariation>

@{
    ViewData["Title"] = "Request Product Restock";
}

<style>
    /* ========================================================
               RequestRestock View - Standalone Isolation Matrix
               ======================================================== */
    .restock-isolated-wrapper {
        display: block !important;
        width: 100% !important;
        max-width: 100% !important;
        contain: inline-size !important;
        box-sizing: border-box !important;
    }

        .restock-isolated-wrapper .row {
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            display: flex !important;
            flex-wrap: wrap !important;
        }

        .restock-isolated-wrapper .card {
            box-sizing: border-box !important;
            transform: none !important;
            transition: none !important;
        }
</style>

<div class="restock-isolated-wrapper">
    <div class="row">
        <div class="col-12">
            
            <div class="card shadow-sm border-0 mt-3 max-w-2xl mx-auto">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="m-0 fw-bold text-dark">🚚 Log Product Delivery Receive</h5>
                    <p class="text-muted small mb-0">Increase warehouse stock profiles via verified supplier manifests</p>
                </div>
                <div class="card-body">
                    <form asp-action="RequestRestock" method="post">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">Select Incoming Component Item</label>
                            <select id="variantSelect" name="MenuVariationId" class="form-select" required>
                                <option value="" disabled selected>-- Choose Variant SKU from Inventory --</option>
                                @foreach (var item in Model)
                                {
                                    <option value="@item.MenuVariationId"
                                            data-productname="@item.Menu?.Name"
                                            data-variantname="@item.VariantName"
                                            data-category="@item.Menu?.Category"
                                            data-currentstock="@item.StockQuantity"
                                            data-retailprice="@item.Price.ToString("F2")"
                                            data-suppliercost="@item.SupplierCost.ToString("F2")">
                                        #@item.MenuVariationId - @item.Menu?.Name (@item.VariantName)
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold small text-muted">Parent Product Name</label>
                                <input type="text" id="displayProductName" class="form-control bg-light" readonly />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold small text-muted">Configuration Type</label>
                                <input type="text" id="displayVariantName" class="form-control bg-light" readonly />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold small text-muted">Inventory Category</label>
                                <input type="text" id="displayCategory" class="form-control bg-light" readonly />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold small text-muted">Current Stock Level</label>
                                <input type="text" id="displayCurrentStock" class="form-control bg-light" readonly />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold small text-muted">Active Retail Price (Selling Price)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-muted">₱</span>
                                    <input type="text" id="displayRetailPrice" class="form-control bg-light fw-bold text-dark" readonly />
                                </div>
                            </div>
                            
                            <div class="col-6 mb-3">
                                <label class="form-label fw-bold small text-muted">Static Supplier Unit Cost (Wholesale Cost)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light text-muted">₱</span>
                                    <input type="text" id="displaySupplierCost" class="form-control bg-light fw-bold text-primary" readonly />
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted opacity-25" />

                        <div class="row">
                            <div class="col-6 mb-4">
                                <label class="form-label fw-bold text-success small">Incoming Delivery Quantity (+)</label>
                                <div class="input-group input-group-lg">
                                    <input type="number" id="quantityInput" name="QuantityReceived" class="form-control fw-bold" min="1" placeholder="Enter amount..." required />
                                    <span class="input-group-text bg-success text-white">units</span>
                                </div>
                            </div>

                            <div class="col-6 mb-4">
                                <label class="form-label fw-bold text-primary small">Estimated Total Delivery Cost (Wholesale Sum)</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-primary text-white">₱</span>
                                    <input type="text" id="displayTotalSupplierCost" class="form-control bg-light fw-bold text-primary" readonly value="0.00" />
                                </div>
                                <input type="hidden" id="rawTotalAmount" name="TotalAmount" value="0.00" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="MenuIndex" class="btn btn-secondary btn-sm px-3">Cancel</a>
                            <button type="submit" class="btn btn-success btn-sm px-4">Verify & Add to Stock</button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    let currentUnitSupplierCost = 0;

    const variantSelect = document.getElementById('variantSelect');
    const quantityInput = document.getElementById('quantityInput');
    const totalCostDisplay = document.getElementById('displayTotalSupplierCost');
    const hiddenTotalInput = document.getElementById('rawTotalAmount');

    variantSelect.addEventListener('change', function () {
        const selectedOption = this.options[this.selectedIndex];

        const productName = selectedOption.getAttribute('data-productname') || '';
        const variantName = selectedOption.getAttribute('data-variantname') || '';
        const category = selectedOption.getAttribute('data-category') || '';
        const currentStock = selectedOption.getAttribute('data-currentstock') || '0';
        const retailPrice = selectedOption.getAttribute('data-retailprice') || '0.00';
        const supplierCost = selectedOption.getAttribute('data-suppliercost') || '0.00';

        currentUnitSupplierCost = parseFloat(supplierCost) || 0;

        document.getElementById('displayProductName').value = productName;
        document.getElementById('displayVariantName').value = variantName;
        document.getElementById('displayCategory').value = category;
        document.getElementById('displayCurrentStock').value = currentStock + " units currently";
        
        document.getElementById('displayRetailPrice').value =
            parseFloat(retailPrice).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            
        document.getElementById('displaySupplierCost').value =
            currentUnitSupplierCost.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

        calculateTotalCost();
    });

    quantityInput.addEventListener('input', calculateTotalCost);

    function calculateTotalCost() {
        const quantity = parseInt(quantityInput.value) || 0;
        
        if (quantity > 0 && currentUnitSupplierCost > 0) {
            const totalSum = quantity * currentUnitSupplierCost;
            
            // Format for professional user view interface display
            totalCostDisplay.value = totalSum.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            
            // Save clean unformatted data straight down to hidden value field buffer
            hiddenTotalInput.value = totalSum.toFixed(2);
        } else {
            totalCostDisplay.value = "0.00";
            hiddenTotalInput.value = "0.00";
        }
    }
</script>