@model IEnumerable<IMDBSYS.Models.ProductDeliveryLog>

@{
    ViewData["Title"] = "Product Restocks Ledger";
}

<style>
    /* ========================================================
           RestockLedger View - Standalone Isolation Matrix
           ======================================================== */

    /* 1. FORCE COMPONENT VIEW PORT ISOLATION CONTROLS */
    .restock-ledger-isolated-wrapper {
        display: block !important;
        width: 100% !important;
        max-width: 100% !important;
        contain: inline-size !important; /* Mathematically freezes internal cell mutations from stretching the layout box */
        box-sizing: border-box !important;
    }

        /* 2. Lock down Bootstrap grid rows from shifting boundaries */
        .restock-ledger-isolated-wrapper .row {
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            display: flex !important;
            flex-wrap: wrap !important;
        }

        /* 3. Force card boundary limitations */
        .restock-ledger-isolated-wrapper .card {
            width: 100% !important;
            max-width: 100% !important;
            box-sizing: border-box !important;
            transform: none !important;
            transition: none !important;
        }

        /* 4. Complete structural lockdown on badge sizes on hover (Intake Qty & Operator Scope) */
        .restock-ledger-isolated-wrapper .table-hover tbody tr:hover td .badge,
        .restock-ledger-isolated-wrapper .table-hover tbody tr td .badge {
            display: inline-block !important;
            text-align: center !important;
            letter-spacing: normal !important;
            transform: none !important;
            transition: none !important;
        }

            /* Keep the Intake Quantity badge fixed so it never changes dimension when hovered */
            .restock-ledger-isolated-wrapper .table-hover tbody tr td .badge.text-success {
                width: 100px !important;
                max-width: 100px !important;
                min-width: 100px !important;
            }

        /* 5. Keep all data grid cells locked into a strict uniform layout footprint */
        .restock-ledger-isolated-wrapper .table-hover tbody tr:hover td,
        .restock-ledger-isolated-wrapper .table-hover tbody tr td {
            height: 65px !important;
            max-height: 65px !important;
            min-height: 65px !important;
            vertical-align: middle !important;
            transition: none !important;
            white-space: nowrap !important;
        }
</style>

<div class="restock-ledger-isolated-wrapper">
    <div class="row">
        <div class="col-12">

            <div class="card shadow-sm border-0 mt-3">
                <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="m-0 fw-bold text-dark">📑 Supply Chain Restock Ledger</h5>
                        <p class="text-muted small mb-0">Historical logs of all inbound product inventory delivery streams</p>
                    </div>
                    <a asp-action="RequestRestock" class="btn btn-primary btn-sm px-3">🚚 Log New Delivery</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 text-center">
                            <thead class="table-light">
                                <tr>
                                    <th>Log ID</th>
                                    <th class="text-start">Inbound Hardware Component SKU</th>
                                    <th>Quantity Added</th>
                                    <th>Total Wholesale Cost</th>
                                    <th>Timestamp Verified</th>
                                    <th>Authorized Operator</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var log in Model)
                                    {
                                        <tr>
                                            <td><code>#@log.DeliveryLogId</code></td>
                                            <td class="text-start">
                                                <div class="fw-bold text-dark">@(log.MenuVariation?.Menu?.Name ?? "Deleted Product Link")</div>
                                                <span class="text-muted small" style="font-size: 11px;">Config Type: @(log.MenuVariation?.VariantName ?? "N/A")</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-success border border-success fw-bold px-2 py-1">
                                                    +@log.QuantityAdded units
                                                </span>
                                            </td>
                                            <td class="text-primary fw-bold">₱@log.TotalAmount.ToString("N2")</td>
                                            <td class="text-muted">@log.DeliveryDate.ToString("yyyy-MM-dd HH:mm pm")</td>
                                            <td><span class="badge bg-secondary opacity-75">@log.ProcessedBy</span></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted">No historical delivery logs found in database repository registers.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>