@model IEnumerable<IMDBSYS.Models.ProductDeliveryLog>

@{
    ViewData["Title"] = "Product Restocks Ledger";
}

<div class="page-header">
    <div>
        <h1>Supply Chain Restock Ledger</h1>
        <p>Historical logs of all inbound product inventory delivery streams</p>
    </div>
    <a asp-action="RequestRestock" class="pk-btn pk-btn-primary pk-btn-sm">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13" />
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
            <circle cx="5.5" cy="18.5" r="2.5" />
            <circle cx="18.5" cy="18.5" r="2.5" />
        </svg>
        Log New Delivery
    </a>
</div>

<div class="pkcard">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table pk-table text-center">
                <thead>
                    <tr>
                        <th class="text-start">Log ID</th>
                        <th class="text-start">Product / Config</th>
                        <th>Quantity Added</th>
                        <th>Total Cost</th>
                        <th>Timestamp</th>
                        <th>Operator</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var log in Model)
                        {
                            <tr>
                                <td class="text-start">
                                    <span style="font-family:monospace; font-size:12px; color:#94a3b8;">#@log.DeliveryLogId</span>
                                </td>
                                <td class="text-start">
                                    <div style="font-weight:700; color:#1e293b;">@(log.MenuVariation?.Menu?.Name ?? "Deleted Product")</div>
                                    <div style="font-size:11px; color:#94a3b8;">@(log.MenuVariation?.VariantName ?? "N/A")</div>
                                </td>
                                <td>
                                    <span class="pk-badge pk-badge-teal">+@log.QuantityAdded units</span>
                                </td>
                                <td style="font-weight:700; color:#2D3A8C;">₱@log.TotalAmount.ToString("N2")</td>
                                <td style="color:#64748b; font-size:12.5px;">@log.DeliveryDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td><span class="pk-badge pk-badge-slate">@log.ProcessedBy</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5" style="color:#94a3b8;">No historical delivery logs found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>