@model IEnumerable<IMDBSYS.Models.Menu>

@{
    ViewData["Title"] = "Menu Management";
}

<div class="page-header">
    <div>
        <h1>Products / Menu</h1>
        <p>Manage catalog offerings, pricing, and variants</p>
    </div>
    <a asp-action="Create" class="pk-btn pk-btn-primary pk-btn-sm">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
        Add New Item
    </a>
</div>

<div class="pkcard">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table pk-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Base Price</th>
                        <th>Variants</th>
                        <th class="text-end" style="padding-right:22px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><span style="font-family:monospace; color:#94a3b8; font-size:12px;">#@item.MenuId</span></td>
                                <td>
                                    <div style="font-weight:700; color:#1e293b;">@item.Name</div>
                                    <div style="font-size:12px; color:#94a3b8; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                        @item.Description
                                    </div>
                                </td>
                                <td><span class="pk-badge pk-badge-navy">@item.Category</span></td>
                                <td style="font-weight:700; color:#1a2563;">₱@item.Price.ToString("N2")</td>
                                <td>
                                    <span class="pk-badge pk-badge-slate">@(item.Variations?.Count ?? 0) configs</span>
                                </td>
                                <td class="text-end" style="padding-right:18px;">
                                    <div class="d-flex justify-content-end gap-2">
                                        <button type="button" class="pk-btn pk-btn-outline pk-btn-sm"
                                                data-bs-toggle="modal" data-bs-target="#editModal-@item.MenuId">
                                            Edit
                                        </button>
                                        <button type="button" class="pk-btn pk-btn-sm"
                                                style="background:#f0f2f8; color:#2D3A8C; border:1.5px solid #c7cde8;"
                                                data-bs-toggle="modal" data-bs-target="#variantsModal-@item.MenuId">
                                            Variants
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5" style="color:#94a3b8;">No menu products found in database registry.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODALS -->
@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <!-- Edit Modal -->
        <div class="modal fade pk-modal" id="editModal-@item.MenuId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Product #@item.MenuId</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div class="modal-body" style="white-space:normal;">
                            <input type="hidden" name="MenuId" value="@item.MenuId" />
                            <div class="row g-4">
                                <!-- Left: image + basic info -->
                                <div class="col-md-5">
                                    <div class="mb-3">
                                        <label class="form-label" style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px;">Product Image</label>
                                        <div style="width:100%; height:150px; background:#f0f2f8; border-radius:14px; border:1.5px dashed #c7cde8; display:flex; align-items:center; justify-content:center; overflow:hidden; margin-bottom:10px;">
                                            @if (!string.IsNullOrEmpty(item.ImagePath))
                                            {
                                                <img src="@item.ImagePath" style="max-width:100%; max-height:100%; object-fit:contain;" alt="Product" />
                                            }
                                            else
                                            {
                                                <span style="font-size:12px; color:#94a3b8; text-align:center;">No image linked</span>
                                            }
                                        </div>
                                        <input type="file" name="ImageFile" class="pk-input form-control" accept="image/*" style="padding:7px 12px;" />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label" style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px;">Product Name</label>
                                        <input type="text" name="Name" class="pk-input form-control" value="@item.Name" required />
                                    </div>

                                    <div class="row g-2 mb-3">
                                        <div class="col-6">
                                            <label class="form-label" style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px;">Category</label>
                                            <input type="text" name="Category" class="pk-input form-control" value="@item.Category" required />
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label" style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px;">Base Price (₱)</label>
                                            <input type="number" step="0.01" name="Price" class="pk-input form-control" value="@item.Price" required />
                                        </div>
                                    </div>

                                    <div>
                                        <label class="form-label" style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px;">Description</label>
                                        <textarea name="Description" class="pk-input form-control" rows="3" required>@item.Description</textarea>
                                    </div>
                                </div>

                                <!-- Right: variants -->
                                <div class="col-md-7">
                                    <label class="form-label" style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px; margin-bottom:12px; display:block;">Configuration Pricing Layers</label>

                                    @if (item.Variations != null && item.Variations.Any())
                                    {
                                        var variationsList = item.Variations.ToList();
                                        <div style="max-height:380px; overflow-y:auto; padding-right:4px;">
                                            @for (int i = 0; i < variationsList.Count; i++)
                                            {
                                                <input type="hidden" name="Variations[@i].MenuVariationId" value="@variationsList[i].MenuVariationId" />
                                                <input type="hidden" name="Variations[@i].MenuId" value="@variationsList[i].MenuId" />
                                                <input type="hidden" name="Variations[@i].VariantName" value="@variationsList[i].VariantName" />
                                                <input type="hidden" name="Variations[@i].StockQuantity" value="@variationsList[i].StockQuantity" />
                                                <input type="hidden" name="Variations[@i].LowStockThreshold" value="@variationsList[i].LowStockThreshold" />

                                                <div style="background:#f8f9ff; border:1.5px solid #e2e8f0; border-radius:14px; padding:14px; margin-bottom:10px;">
                                                    <div class="row align-items-center g-2">
                                                        <div class="col-6">
                                                            <div style="font-size:11px; color:#94a3b8; margin-bottom:2px;">Specification</div>
                                                            <div style="font-weight:700; color:#1e293b; font-size:13.5px;">@variationsList[i].VariantName</div>
                                                            <div style="font-size:11px; color:#94a3b8; margin-top:2px;">Stock: @variationsList[i].StockQuantity units</div>
                                                        </div>
                                                        <div class="col-6">
                                                            <label style="font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.6px; display:block; margin-bottom:6px;">Retail Price (₱)</label>
                                                            <div class="input-group input-group-sm">
                                                                <span class="input-group-text" style="background:#e0e4f8; border-color:#c7cde8; color:#2D3A8C; font-weight:700;">₱</span>
                                                                <input type="number" step="0.01" name="Variations[@i].Price"
                                                                       class="pk-input form-control"
                                                                       style="border-radius:0 10px 10px 0 !important;"
                                                                       value="@variationsList[i].Price" required />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center py-5" style="color:#94a3b8; font-size:13px;">
                                            No configuration variants exist for this item.
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="pk-btn pk-btn-outline pk-btn-sm" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="pk-btn pk-btn-primary pk-btn-sm">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Variants Modal -->
        <div class="modal fade pk-modal" id="variantsModal-@item.MenuId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Variants: @item.Name</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body" style="white-space:normal;">
                        <div class="table-responsive">
                            <table class="table pk-table text-center">
                                <thead>
                                    <tr>
                                        <th>Var ID</th>
                                        <th class="text-start">Specification</th>
                                        <th>Retail Price</th>
                                        <th>Stock</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (item.Variations != null && item.Variations.Any())
                                    {
                                        foreach (var variant in item.Variations)
                                        {
                                            <tr>
                                                <td><span style="font-family:monospace; color:#94a3b8; font-size:12px;">#@variant.MenuVariationId</span></td>
                                                <td class="text-start" style="font-weight:600; color:#1e293b;">@variant.VariantName</td>
                                                <td style="font-weight:700; color:#1a2563;">₱@variant.Price.ToString("N2")</td>
                                                <td>@variant.StockQuantity units</td>
                                                <td>
                                                    @if (variant.StockQuantity <= variant.LowStockThreshold)
                                                    {
                                                        <span class="pk-badge pk-badge-danger">Critical Stock</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="pk-badge pk-badge-success">Healthy</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="5" class="text-center py-4" style="color:#94a3b8;">No variants linked to this product.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="pk-btn pk-btn-outline pk-btn-sm" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
}