@model IEnumerable<IMDBSYS.Models.Menu>

@{
    ViewData["Title"] = "Menu Management";
}

<style>

    .menu-filter-input,
    .menu-filter-select {
        height: 46px !important;
        border-radius: 12px !important;
        border: 1px solid #dbe2ea !important;
        font-size: 15px;
        color: #1e293b;
        box-shadow: none !important;
        transition: all 0.2s ease;
    }

        .menu-filter-input:focus,
        .menu-filter-select:focus {
            border-color: #4f46e5 !important;
            box-shadow: 0 0 0 3px rgba(79,70,229,0.12) !important;
        }

    .menu-filter-input {
        padding-left: 16px !important;
        padding-right: 38px !important;
    }

    .menu-clear-btn {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #94a3b8;
        font-size: 18px;
        font-weight: 700;
        transition: 0.2s ease;
        user-select: none;
    }

        .menu-clear-btn:hover {
            color: #475569;
        }

</style>

<div class="page-header">
    <div>
        <h1>Products / Menu</h1>
        <p>Manage catalog offerings, pricing, and variants</p>
    </div>

    <a asp-action="Create" class="pk-btn pk-btn-primary pk-btn-sm">
        <svg width="13"
             height="13"
             viewBox="0 0 24 24"
             fill="none"
             stroke="currentColor"
             stroke-width="3"
             stroke-linecap="round">

            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />

        </svg>

        Add New Item
    </a>
</div>

<div class="pkcard">

    <!-- SEARCH + FILTER -->
    <div class="card-body border-bottom" style="padding:18px;">

        <div class="row g-3">

            <!-- Search -->
            <div class="col-md-5">

                <div style="position:relative;">

                    <input type="text"
                           id="menuSearchInput"
                           class="form-control menu-filter-input"
                           placeholder="Search by product name or description..."
                           onkeyup="filterTable()" />

                    <!-- Clear -->
                    <span class="menu-clear-btn"
                          onclick="clearSearch()">
                        ×
                    </span>

                </div>

            </div>

            <!-- Category Filter -->
            <div class="col-md-3">

                <select id="categoryFilter"
                        class="form-select menu-filter-select"
                        onchange="filterTable()">

                    <option value="">All Categories</option>

                    @foreach (var cat in Model.Select(m => m.Category).Distinct().OrderBy(c => c))
                    {
                        <option value="@cat">@cat</option>
                    }

                </select>

            </div>

        </div>

    </div>

    <!-- TABLE -->
    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table pk-table" id="menuTable">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Base Price</th>
                        <th>Variants</th>
                        <th class="text-end" style="padding-right:22px;">
                            Actions
                        </th>
                    </tr>
                </thead>

                <tbody id="menuTableBody">

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="menu-row"
                                data-name="@item.Name.ToLower()"
                                data-description="@(item.Description?.ToLower() ?? "")"
                                data-category="@item.Category">

                                <!-- ID -->
                                <td>

                                    <span style="
                                                    font-family:monospace;
                                                    color:#94a3b8;
                                                    font-size:12px;">

                                        #@item.MenuId

                                    </span>

                                </td>

                                <!-- Product -->
                                <td>

                                    <div style="
                                                    font-weight:700;
                                                    color:#1e293b;">

                                        @item.Name

                                    </div>

                                    <div style="
                                                    font-size:12px;
                                                    color:#94a3b8;
                                                    max-width:280px;
                                                    overflow:hidden;
                                                    text-overflow:ellipsis;
                                                    white-space:nowrap;">

                                        @item.Description

                                    </div>

                                </td>

                                <!-- Category -->
                                <td>

                                    <span class="pk-badge pk-badge-navy">

                                        @item.Category

                                    </span>

                                </td>

                                <!-- Price -->
                                <td style="
                                                font-weight:700;
                                                color:#1a2563;">

                                    ₱@item.Price.ToString("N2")

                                </td>

                                <!-- Variants -->
                                <td>

                                    <span class="pk-badge pk-badge-slate">

                                        @(item.Variations?.Count ?? 0) configs

                                    </span>

                                </td>

                                <!-- Actions -->
                                <td class="text-end"
                                    style="padding-right:18px;">

                                    <div class="d-flex justify-content-end gap-2">

                                        <button type="button"
                                                class="pk-btn pk-btn-outline pk-btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editModal-@item.MenuId">

                                            Edit

                                        </button>

                                        <button type="button"
                                                class="pk-btn pk-btn-sm"
                                                style="
                                                            background:#f0f2f8;
                                                            color:#2D3A8C;
                                                            border:1.5px solid #c7cde8;"
                                                data-bs-toggle="modal"
                                                data-bs-target="#variantsModal-@item.MenuId">

                                            Variants

                                        </button>

                                    </div>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="6"
                                class="text-center py-5"
                                style="color:#94a3b8;">

                                No menu products found.

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

            <!-- EMPTY STATE -->
            <div id="noResultsMsg"
                 style="
                    display:none;
                    text-align:center;
                    padding:48px 20px;
                    color:#94a3b8;">

                <div style="
                        font-size:14px;
                        font-weight:600;
                        margin-bottom:4px;">

                    No products match your search

                </div>

                <div style="font-size:12.5px;">

                    Try a different name or category filter

                </div>

            </div>

        </div>

    </div>

</div>

<!-- MODALS -->
@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <!-- Edit Modal -->
        <div class="modal fade pk-modal"
             id="editModal-@item.MenuId"
             tabindex="-1"
             aria-hidden="true">

            <div class="modal-dialog modal-dialog-centered modal-lg">

                <div class="modal-content">

                    <div class="modal-header">

                        <h5 class="modal-title">
                            Edit Product #@item.MenuId
                        </h5>

                        <button type="button"
                                class="btn-close btn-close-white"
                                data-bs-dismiss="modal">
                        </button>

                    </div>

                    <form asp-action="Edit"
                          method="post"
                          enctype="multipart/form-data">

                        <div class="modal-body"
                             style="white-space:normal;">

                            <input type="hidden"
                                   name="MenuId"
                                   value="@item.MenuId" />

                            <!-- KEEP YOUR ORIGINAL MODAL CONTENT HERE -->

                        </div>

                        <div class="modal-footer">

                            <button type="button"
                                    class="pk-btn pk-btn-outline pk-btn-sm"
                                    data-bs-dismiss="modal">

                                Cancel

                            </button>

                            <button type="submit"
                                    class="pk-btn pk-btn-primary pk-btn-sm">

                                Save Changes

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

        <!-- Variants Modal -->
        <div class="modal fade pk-modal"
             id="variantsModal-@item.MenuId"
             tabindex="-1"
             aria-hidden="true">

            <div class="modal-dialog modal-lg modal-dialog-centered">

                <div class="modal-content">

                    <div class="modal-header">

                        <h5 class="modal-title">
                            Variants: @item.Name
                        </h5>

                        <button type="button"
                                class="btn-close btn-close-white"
                                data-bs-dismiss="modal">
                        </button>

                    </div>

                    <div class="modal-body"
                         style="white-space:normal;">

                        <!-- KEEP YOUR ORIGINAL VARIANTS CONTENT HERE -->

                    </div>

                    <div class="modal-footer">

                        <button type="button"
                                class="pk-btn pk-btn-outline pk-btn-sm"
                                data-bs-dismiss="modal">

                            Close

                        </button>

                    </div>

                </div>

            </div>

        </div>
    }
}

@section Scripts {

    <script>

        function filterTable() {

            let search =
                document.getElementById("menuSearchInput")
                .value
                .toLowerCase();

            let category =
                document.getElementById("categoryFilter")
                .value;

            let rows =
                document.querySelectorAll(".menu-row");

            let visible = 0;

            rows.forEach(row => {

                let name =
                    row.dataset.name || "";

                let description =
                    row.dataset.description || "";

                let rowCategory =
                    row.dataset.category || "";

                let matchesSearch =
                    name.includes(search) ||
                    description.includes(search);

                let matchesCategory =
                    category === "" ||
                    rowCategory === category;

                if (matchesSearch && matchesCategory) {

                    row.style.display = "";
                    visible++;

                }
                else {

                    row.style.display = "none";
                }

            });

            document.getElementById("noResultsMsg").style.display =
                visible === 0 ? "block" : "none";
        }

        function clearSearch() {

            document.getElementById("menuSearchInput").value = "";

            filterTable();
        }

    </script>

}