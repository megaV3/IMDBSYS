@model IEnumerable<IMDBSYS.Models.Menu>

@{
    ViewData["Title"] = "Menu Management";
}

<style>
    /* ========================================================
           Global Control Layout Filters & Text inputs
           ======================================================== */
    .menu-filter-input,
    .menu-filter-select {
        height: 46px !important;
        border-radius: 12px !important;
        border: 1px solid #dbe2ea !important;
        font-size: 15px;
        color: #1e293b;
        box-shadow: none !important;
        transition: all 0.2s ease;
    }

        .menu-filter-input:focus,
        .menu-filter-select:focus {
            border-color: #3E4885 !important;
            box-shadow: 0 0 0 3px rgba(62,72,133,0.12) !important;
        }

    .menu-filter-input {
        padding-left: 16px !important;
        padding-right: 38px !important;
    }

    .menu-clear-btn {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #94a3b8;
        font-size: 18px;
        font-weight: 700;
        transition: 0.2s ease;
        user-select: none;
    }

        .menu-clear-btn:hover {
            color: #475569;
        }

    /* ========================================================
           Custom Premium Modal Styling Engine (Matches your UI)
           ======================================================== */
    .pk-modal .modal-content {
        border-radius: 24px !important;
        border: none !important;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15) !important;
    }

    .pk-modal .modal-header {
        background-color: #1E2963 !important; /* Premium Navy Header from UI */
        color: #fff !important;
        padding: 18px 28px !important;
        border-bottom: none !important;
    }

    .pk-modal .modal-title {
        font-size: 18px !important;
        font-weight: 700 !important;
        letter-spacing: -0.3px;
    }

    .pk-modal .modal-body {
        padding: 28px !important;
        background-color: #fff;
    }

    .pk-modal .form-section-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #7B88B5;
        margin-bottom: 12px;
    }

    .pk-modal .form-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #7B88B5;
        margin-bottom: 6px;
    }

    .pk-modal .form-control,
    .pk-modal .form-select {
        border: 1.5px solid #E2E8F0 !important;
        border-radius: 12px !important;
        padding: 10px 14px;
        font-size: 14px;
        color: #1E1E2F;
        font-weight: 500;
        box-shadow: none !important;
        background-color: #fff;
    }

        .pk-modal .form-control:focus {
            border-color: #3E4885 !important;
        }

    /* Left side Image container framing */
    .pk-modal .img-upload-frame {
        border: 1.5px dashed #C7CDE8;
        border-radius: 16px;
        background-color: #F8FAFC;
        padding: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 160px;
        margin-bottom: 12px;
    }

    /* Right side variants configuration wrapper card */
    .pk-modal .variant-pricing-scroll-box {
        max-height: 395px;
        overflow-y: auto;
        padding-right: 6px;
    }

        /* Custom tracking thin line scrollbar */
        .pk-modal .variant-pricing-scroll-box::-webkit-scrollbar {
            width: 6px;
        }

        .pk-modal .variant-pricing-scroll-box::-webkit-scrollbar-thumb {
            background-color: #CBD5E1;
            border-radius: 10px;
        }

    .pk-modal .variant-pricing-card {
        background: #fff;
        border: 1.5px solid #E2E8F0;
        border-radius: 16px;
        padding: 14px 18px;
        margin-bottom: 12px;
        transition: border-color 0.2s;
    }

        .pk-modal .variant-pricing-card:hover {
            border-color: #C7CDE8;
        }

    .pk-modal .variant-currency-addon {
        background-color: #EBF0FF !important;
        border: 1.5px solid #D6DCFA !important;
        border-right: none !important;
        color: #2D3A8C !important;
        font-weight: 700;
        border-radius: 12px 0 0 12px !important;
    }

    .pk-modal .variant-price-input {
        border-radius: 0 12px 12px 0 !important;
    }

    .pk-modal .modal-footer {
        padding: 16px 28px !important;
        background-color: #F8FAFC;
        border-top: 1.5px solid #E2E8F0 !important;
    }
</style>

<div class="page-header">
    <div>
        <h1>Products / Menu</h1>
        <p>Manage catalog offerings, pricing, and variants</p>
    </div>

    <button type="button" class="pk-btn pk-btn-primary pk-btn-sm" data-bs-toggle="modal" data-bs-target="#addNewItemModal">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        Add New Item
    </button>
</div>

<div class="pkcard">
    <div class="card-body border-bottom" style="padding:18px;">
        <div class="row g-3">
            <div class="col-md-5">
                <div style="position:relative;">
                    <input type="text" id="menuSearchInput" class="form-control menu-filter-input" placeholder="Search by product name or description..." onkeyup="filterTable()" />
                    <span class="menu-clear-btn" onclick="clearSearch()">×</span>
                </div>
            </div>
            <div class="col-md-3">
                <select id="categoryFilter" class="form-select menu-filter-select" onchange="filterTable()">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Select(m => m.Category).Distinct().OrderBy(c => c))
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table pk-table" id="menuTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Base Price</th>
                        <th>Variants</th>
                        <th class="text-end" style="padding-right:22px;">Actions</th>
                    </tr>
                </thead>
                <tbody id="menuTableBody">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="menu-row" data-name="@item.Name.ToLower()" data-description="@(item.Description?.ToLower() ?? "")" data-category="@item.Category">
                                <td><span style="font-family:monospace; color:#94a3b8; font-size:12px;">#@item.MenuId</span></td>
                                <td>
                                    <div style="font-weight:700; color:#1e293b;">@item.Name</div>
                                    <div style="font-size:12px; color:#94a3b8; max-width:280px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@item.Description</div>
                                </td>
                                <td><span class="pk-badge pk-badge-navy">@item.Category</span></td>
                                <td style="font-weight:700; color:#1a2563;">₱@item.Price.ToString("N2")</td>
                                <td><span class="pk-badge pk-badge-slate">@(item.Variations?.Count ?? 0) configs</span></td>
                                <td class="text-end" style="padding-right:18px;">
                                    <div class="d-flex justify-content-end gap-2">
                                        <button type="button" class="pk-btn pk-btn-outline pk-btn-sm" data-bs-toggle="modal" data-bs-target="#editModal-@item.MenuId">Edit</button>
                                        <button type="button" class="pk-btn pk-btn-sm" style="background:#f0f2f8; color:#2D3A8C; border:1.5px solid #c7cde8;" data-bs-toggle="modal" data-bs-target="#variantsModal-@item.MenuId">Variants</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5" style="color:#94a3b8;">No menu products found.</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div id="noResultsMsg" style="display:none; text-align:center; padding:48px 20px; color:#94a3b8;">
                <div style="font-size:14px; font-weight:600; margin-bottom:4px;">No products match your search</div>
                <div style="font-size:12.5px;">Try a different name or category filter</div>
            </div>
        </div>
    </div>
</div>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <div class="modal fade pk-modal" id="editModal-@item.MenuId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Product #@item.MenuId</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>

                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <div class="modal-body"
                             style="
                background:#f8fafc;
                padding:20px 22px;
                white-space:normal;">

                            <input type="hidden"
                                   name="MenuId"
                                   value="@item.MenuId" />

                            <div class="row g-3">

                                <!-- LEFT -->
                                <div class="col-lg-4">

                                    <div style="
                            background:#fff;
                            border:1px solid #e2e8f0;
                            border-radius:18px;
                            padding:18px;">

                                        <!-- IMAGE -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Product Image
                                            </label>

                                            <div style="
                                    height:180px;
                                    border-radius:16px;
                                    border:1.5px dashed #CBD5E1;
                                    background:
                                        linear-gradient(
                                            180deg,
                                            #F8FAFC 0%,
                                            #F1F5F9 100%
                                        );

                                    display:flex;
                                    align-items:center;
                                    justify-content:center;

                                    overflow:hidden;">

                                                <img src="@(string.IsNullOrEmpty(item.ImagePath)
                                                                                     ? "/images/profiles/default-picture.webp"
                                                                                     : item.ImagePath)"
                                                     style="
                                        max-width:75%;
                                        max-height:135px;
                                        object-fit:contain;" />

                                            </div>

                                        </div>

                                        <!-- FILE -->
                                        <div class="mb-3">

                                            <input type="file"
                                                   name="ImageFile"
                                                   class="form-control form-control-sm"
                                                   accept="image/*" />

                                        </div>

                                        <!-- NAME -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Product Name
                                            </label>

                                            <input type="text"
                                                   name="Name"
                                                   class="form-control"
                                                   value="@item.Name"
                                                   required />

                                        </div>

                                        <!-- CATEGORY -->
                                        <div class="mb-3">

                                            <label class="form-label">
                                                Category
                                            </label>

                                            <input type="text"
                                                   name="Category"
                                                   class="form-control"
                                                   value="@item.Category"
                                                   required />

                                        </div>

                                        <!-- PRICE -->
                                        <div>

                                            <label class="form-label">
                                                Base Price
                                            </label>

                                            <div class="input-group">

                                                <span class="input-group-text"
                                                      style="
                                        background:#EEF2FF;
                                        color:#2D3A8C;
                                        font-weight:700;">

                                                    ₱

                                                </span>

                                                <input type="number"
                                                       step="0.01"
                                                       name="Price"
                                                       class="form-control fw-bold"
                                                       value="@item.Price"
                                                       required />

                                            </div>

                                        </div>

                                    </div>

                                </div>

                                <!-- RIGHT -->
                                <div class="col-lg-8">

                                    <div style="
                            background:#fff;
                            border:1px solid #e2e8f0;
                            border-radius:18px;
                            padding:18px;">

                                        <!-- DESCRIPTION -->
                                        <div class="mb-4">

                                            <div class="form-section-title mb-2">
                                                Product Details
                                            </div>

                                            <textarea name="Description"
                                              class="form-control"
                                              rows="4"
                                              required>@item.Description</textarea>

                                        </div>

                                        <!-- VARIANTS -->
                                        <div>

                                            <div class="d-flex justify-content-between align-items-center mb-3">

                                                <div class="form-section-title mb-0">
                                                    Variant Pricing
                                                </div>

                                                <span class="pk-badge pk-badge-navy">

                                                    @(item.Variations?.Count ?? 0)
                                                    Variants

                                                </span>

                                            </div>

                                            <div style="
                                    max-height:300px;
                                    overflow-y:auto;
                                    padding-right:4px;">

                                                @if (item.Variations != null && item.Variations.Any())
                                                {
                                                    int varIdx = 0;

                                                    foreach (var variant in item.Variations)
                                                    {
                                                        <div style="
                                                        border:1px solid #E2E8F0;
                                                        border-radius:14px;
                                                        padding:14px 16px;
                                                        margin-bottom:10px;
                                                        background:#fff;">

                                                            <input type="hidden"
                                                                   name="Variations[@varIdx].MenuVariationId"
                                                                   value="@variant.MenuVariationId" />

                                                            <input type="hidden"
                                                                   name="Variations[@varIdx].MenuId"
                                                                   value="@variant.MenuId" />

                                                            <input type="hidden"
                                                                   name="Variations[@varIdx].VariantName"
                                                                   value="@variant.VariantName" />

                                                            <div class="d-flex justify-content-between align-items-center">

                                                                <!-- LEFT -->
                                                                <div>

                                                                    <div style="
                                                                    font-size:14px;
                                                                    font-weight:700;
                                                                    color:#1e293b;">

                                                                        @variant.VariantName

                                                                    </div>

                                                                    <div style="
                                                                    font-size:12px;
                                                                    color:#94a3b8;">

                                                                        Stock:
                                                                        @variant.StockQuantity units

                                                                    </div>

                                                                </div>

                                                                <!-- RIGHT -->
                                                                <div style="width:160px;">

                                                                    <div class="input-group input-group-sm">

                                                                        <span class="input-group-text"
                                                                              style="
                                                                        background:#EEF2FF;
                                                                        color:#2D3A8C;
                                                                        font-weight:700;">

                                                                            ₱

                                                                        </span>

                                                                        <input type="number"
                                                                               step="0.01"
                                                                               name="Variations[@varIdx].Price"
                                                                               class="form-control text-end fw-bold"
                                                                               value="@variant.Price"
                                                                               required />

                                                                    </div>

                                                                </div>

                                                            </div>

                                                        </div>

                                                        varIdx++;
                                                    }
                                                }

                                            </div>

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>
                        <div class="modal-footer">
                            <button type="button" class="pk-btn pk-btn-outline pk-btn-sm" data-bs-dismiss="modal" style="border-radius: 12px; padding: 10px 24px;">Cancel</button>
                            <button type="submit" class="pk-btn pk-btn-primary pk-btn-sm" style="border-radius: 12px; padding: 10px 24px; background-color: #1E2963;">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade pk-modal" id="variantsModal-@item.MenuId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header" style="background-color: #2D3A8C !important;">
                        <h5 class="modal-title">Variants: @item.Name</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body p-0" style="white-space:normal;">
                        <div class="table-responsive">
                            <table class="table align-middle text-center mb-0">
                                <thead class="table-light small text-uppercase fw-bold text-muted">
                                    <tr>
                                        <th>Config ID</th>
                                        <th class="text-start">Specification Value Label</th>
                                        <th>Fulfillment Unit Price</th>
                                        <th>Warehouse Stock</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (item.Variations != null && item.Variations.Any())
                                    {
                                        foreach (var variant in item.Variations)
                                        {
                                            <tr>
                                                <td><code>VAR-@variant.MenuVariationId.ToString("D3")</code></td>
                                                <td class="text-start fw-bold text-dark">@variant.VariantName</td>
                                                <td class="fw-bold" style="color: #2D3A8C;">₱@variant.Price.ToString("N2")</td>
                                                <td>
                                                    @if (variant.StockQuantity <= 0)
                                                    {
                                                        <span class="badge bg-danger p-2">🔴 Out of Stock</span>
                                                    }
                                                    else if (variant.StockQuantity <= 15)
                                                    {
                                                        <span class="badge bg-warning text-dark p-2">⚠️ Low Stock (@variant.StockQuantity)</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-success p-2">🟢 Good (@variant.StockQuantity units)</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center py-4 text-muted small">No structural configuration variant indices found mapping onto this core hardware product component record.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="modal-footer py-2">
                        <button type="button" class="pk-btn pk-btn-outline pk-btn-sm" data-bs-dismiss="modal" style="border-radius: 12px;">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
}
<div class="modal fade pk-modal"
     id="addNewItemModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered modal-xl">

        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">

                <h5 class="modal-title">
                    Register New Product Component
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <!-- FORM -->
            <form asp-action="Create"
                  method="post"
                  enctype="multipart/form-data">

                <div class="modal-body"
                     style="
                        background:#f8fafc;
                        padding:20px 22px;
                        white-space:normal;">

                    <div class="row g-3">

                        <!-- LEFT -->
                        <div class="col-md-5 border-end pe-4"
                             style="border-color:#E2E8F0 !important;">

                            <!-- TITLE -->
                            <div class="form-section-title mb-3">
                                Product Details
                            </div>

                            <!-- IMAGE -->
                            <div class="mb-3">

                                <div class="img-upload-frame"
                                     id="createImgPreviewFrame"
                                     style="
                                        min-height:180px;
                                        border-radius:18px;
                                        border:1.5px dashed #CBD5E1;
                                        background:
                                            linear-gradient(
                                                180deg,
                                                #F8FAFC 0%,
                                                #F1F5F9 100%
                                            );

                                        display:flex;
                                        align-items:center;
                                        justify-content:center;">

                                    <div style="text-align:center;">

                                        <div style="
                                                font-size:14px;
                                                font-weight:600;
                                                color:#64748B;
                                                margin-bottom:3px;">

                                            Upload Product Thumbnail

                                        </div>

                                        <div style="
                                                font-size:12px;
                                                color:#4F46E5;
                                                font-weight:700;">

                                            JPG, PNG or WEBP

                                        </div>

                                    </div>

                                </div>

                            </div>

                            <!-- FILE -->
                            <div class="mb-4">

                                <input type="file"
                                       name="ImageFile"
                                       id="createImgFileInput"
                                       class="form-control"
                                       accept="image/*"
                                       required />

                            </div>

                            <!-- NAME -->
                            <div class="mb-3">

                                <label class="form-label">
                                    Product Name
                                </label>

                                <input type="text"
                                       name="Name"
                                       class="form-control"
                                       placeholder="e.g., Kingston KC600 SSD Sata 3"
                                       required />

                            </div>

                            <!-- CATEGORY + PRICE -->
                            <div class="row g-3 mb-3">

                                <!-- CATEGORY -->
                                <div class="col-6">

                                    <label class="form-label">
                                        Category
                                    </label>

                                    <select name="Category"
                                            class="form-select"
                                            required>

                                        <option value=""
                                                disabled
                                                selected>

                                            Select category...

                                        </option>

                                        <option value="StorageDevices">
                                            Storage Devices
                                        </option>

                                        <option value="RAM">
                                            RAM
                                        </option>

                                        <option value="PSU">
                                            PSU
                                        </option>

                                        <option value="inputDevices">
                                            Input Devices
                                        </option>

                                        <option value="outputDevices">
                                            Output Devices
                                        </option>

                                    </select>

                                </div>

                                <!-- PRICE -->
                                <div class="col-6">

                                    <label class="form-label">
                                        Base Price (₱)
                                    </label>

                                    <input type="number"
                                           step="0.01"
                                           name="Price"
                                           class="form-control fw-bold"
                                           placeholder="0.00"
                                           required />

                                </div>

                            </div>

                            <!-- DESCRIPTION -->
                            <div>

                                <label class="form-label">
                                    Description
                                </label>

                                <textarea name="Description"
                                          class="form-control"
                                          rows="4"
                                          placeholder="Enter detailed technical specifications..."
                                          required></textarea>

                            </div>

                        </div>

                        <!-- RIGHT -->
                        <div class="col-md-7 ps-4">

                            <!-- TITLE -->
                            <div class="form-section-title">
                                Initial Configuration Layers
                            </div>

                            <p class="text-muted small mb-3"
                               style="margin-top:-6px;">

                                Configure stock quantities and pricing layers
                                for each product variation.

                            </p>

                            <!-- VARIANT BOX -->
                            <div class="variant-pricing-scroll-box"
                                 id="newItemVariantsBox">

                                <!-- DEFAULT -->
                                <div class="variant-pricing-card">

                                    <div class="row align-items-center g-3">

                                        <!-- SPEC -->
                                        <div class="col-4 text-start">

                                            <label class="form-label mb-1">
                                                Spec Label
                                            </label>

                                            <input type="text"
                                                   name="Variations[0].VariantName"
                                                   class="form-control form-control-sm fw-bold"
                                                   value="Standard"
                                                   required />

                                        </div>

                                        <!-- STOCK -->
                                        <div class="col-4">

                                            <label class="form-label mb-1">
                                                Stock Qty
                                            </label>

                                            <input type="number"
                                                   name="Variations[0].StockQuantity"
                                                   class="form-control form-control-sm text-center"
                                                   value="10"
                                                   min="0"
                                                   required />

                                        </div>

                                        <!-- PRICE -->
                                        <div class="col-4">

                                            <label class="form-label mb-1">
                                                Unit Price
                                            </label>

                                            <div class="input-group input-group-sm">

                                                <span class="input-group-text"
                                                      style="
                                                        background:#EEF2FF;
                                                        color:#2D3A8C;
                                                        font-weight:700;">

                                                    ₱

                                                </span>

                                                <input type="number"
                                                       step="0.01"
                                                       name="Variations[0].Price"
                                                       class="form-control text-end fw-bold"
                                                       placeholder="0.00"
                                                       required />

                                            </div>

                                        </div>

                                    </div>

                                </div>

                            </div>

                            <!-- BUTTON -->
                            <button type="button"
                                    class="btn btn-sm w-100 mt-2"
                                    onclick="addNewCreationVariantRow()"
                                    style="
                                        border:1.5px dashed #C7CDE8;
                                        border-radius:14px;
                                        background:#fff;
                                        color:#4F46E5;
                                        padding:11px;
                                        font-size:13px;
                                        font-weight:700;">

                                Append Additional Specification Variant Row

                            </button>

                        </div>

                    </div>

                </div>

                <!-- FOOTER -->
                <div class="modal-footer">

                    <button type="button"
                            class="pk-btn pk-btn-outline pk-btn-sm"
                            data-bs-dismiss="modal"
                            style="
                                border-radius:12px;
                                padding:10px 24px;">

                        Cancel

                    </button>

                    <button type="submit"
                            class="pk-btn pk-btn-primary pk-btn-sm"
                            style="
                                border-radius:12px;
                                padding:10px 24px;
                                background-color:#1E2963;">

                        Create Product Component

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
@section Scripts {
    <script>
        function filterTable() {
            let search = document.getElementById("menuSearchInput").value.toLowerCase();
            let category = document.getElementById("categoryFilter").value;
            let rows = document.querySelectorAll(".menu-row");
            let visible = 0;

            rows.forEach(row => {
                let name = row.dataset.name || "";
                let description = row.dataset.description || "";
                let rowCategory = row.dataset.category || "";

                let matchesSearch = name.includes(search) || description.includes(search);
                let matchesCategory = category === "" || rowCategory === category;

                if (matchesSearch && matchesCategory) {
                    row.style.display = "";
                    visible++;
                } else {
                    row.style.display = "none";
                }
            });

            document.getElementById("noResultsMsg").style.display = visible === 0 ? "block" : "none";
        }

        function clearSearch() {
            document.getElementById("menuSearchInput").value = "";
            filterTable();
        }

            // 1. LIVE IMAGE FILE PREVIEW UTILITY FOR THE ADD MODAL
        document.getElementById('createImgFileInput')?.addEventListener('change', function (e) {
            if (e.target.files && e.target.files[0]) {
                const reader = new FileReader();
                reader.onload = function (event) {
                    const frame = document.getElementById('createImgPreviewFrame');
                    if (frame) {
                        frame.innerHTML = `<img src="${event.target.result}" style="max-height:140px; object-fit:contain;" alt="Preview Thumbnail" />`;
                    }
                };
                reader.readAsDataURL(e.target.files[0]);
            }
        });

        // 2. DYNAMICALLY APPEND VARIABLE VARIANT ROW ENTRIES ON CLICK
        var _newFormVariantCounter = 1;
        function addNewCreationVariantRow() {
            const targetBox = document.getElementById('newItemVariantsBox');
            if (!targetBox) return;

            const rowDiv = document.createElement('div');
            rowDiv.className = 'variant-pricing-card position-relative animate-fade-in';
            rowDiv.innerHTML = `
                <div class="row align-items-center g-3">
                    <div class="col-4 text-start">
                        <label class="form-label mb-1">Spec Label</label>
                        <input type="text" name="Variations[${_newFormVariantCounter}].VariantName" class="form-control form-control-sm font-monospace fw-bold" placeholder="e.g., 512GB" required />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-1">Stock Qty</label>
                        <input type="number" name="Variations[${_newFormVariantCounter}].StockQuantity" class="form-control form-control-sm text-center" value="10" min="0" required />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-1">Unit Price</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light fw-bold text-muted" style="font-size: 11px;">₱</span>
                            <input type="number" step="0.01" name="Variations[${_newFormVariantCounter}].Price" class="form-control form-control-sm text-end fw-bold" placeholder="0.00" required />
                        </div>
                    </div>
                </div>
                <button type="button" class="btn-close position-absolute" style="top: 6px; right: 8px; font-size: 10px;" onclick="this.parentElement.remove()" aria-label="Remove Row"></button>
            `;
            targetBox.appendChild(rowDiv);
            _newFormVariantCounter++;
        }
    </script>
}