@model IEnumerable<IMDBSYS.Models.TopUpHistory>

@{
    ViewData["Title"] = "Wallet Ledger";
}

<div class="page-header">
    <div>
        <h1>Wallet Top-Up Ledger</h1>
        <p>Financial balance change histories and transaction records</p>
    </div>
</div>

<div class="pkcard">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table pk-table">
                <thead>
                    <tr>
                        <th>Transaction ID</th>
                        <th>Account</th>
                        <th>Account Owner</th>
                        <th>Method</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th class="text-end" style="padding-right:22px;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var txn in Model)
                        {
                            <tr>
                                <td>
                                    <span style="font-family:monospace; font-size:12px; color:#64748b;">@txn.TransactionId</span>
                                </td>
                                <td>
                                    <div style="font-weight:700; color:#1e293b; font-size:13px;">@txn.Email</div>
                                    <div style="font-size:11px; color:#94a3b8;">USR-@txn.UserId.ToString("D4")</div>
                                </td>
                                <td style="font-weight:600; color:#1e293b;">@txn.FirstName @txn.LastName</td>
                                <td><span class="pk-badge pk-badge-slate">@txn.PaymentMethod</span></td>
                                <td style="font-weight:700; color:#15803d;">+₱@txn.Amount.ToString("N2")</td>
                                <td style="color:#64748b; font-size:12.5px;">@txn.TransactionDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end" style="padding-right:18px;">
                                    <span class="pk-badge @(txn.Status == "Success" || txn.Status == "Approved" ? "pk-badge-success" : "pk-badge-danger")">
                                        @txn.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5" style="color:#94a3b8;">No financial history logs found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>