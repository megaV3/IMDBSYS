@model List<IMDBSYS.Models.OrderItem>

@{
    ViewData["Title"] = "Your Cart";
    var subtotal = Model?.Sum(i => i.Total) ?? 0;
    var tax = subtotal * 0.12m;
    var total = subtotal + tax;
}

<link href="~/css/cart.css" rel="stylesheet" />

<div class="navbar">

    <div class="nav-left">
        <h2>PICKOUT HARDWARE</h2>
    </div>

    <div class="nav-center">
        <a asp-controller="Store" asp-action="Index" class="nav-link active">Home</a>
    </div>

    <div class="nav-right">
        @if (ViewBag.IsCartEmpty != true) // Handled fallback condition safely
        {
            <div class="nav-balance">
                <span class="balance-label">₱</span>
                <span class="balance-amount">@(((decimal)(ViewBag.UserBalance ?? 0m)).ToString("0.00"))</span>
            </div>
        }
        <a asp-controller="Order" asp-action="Cart">
            <div class="cart-wrapper">
                <img class="cart-img default-img" src="~/images/cart-grey.png" alt="Cart" />
            </div>
        </a>

        <a asp-controller="Identity" asp-action="Profile" class="nav-icon active-profile">
            <img class="nav-icon active-profile" src="@Url.Content(ViewBag.ProfileImagePath)" />
        </a>
    </div>

</div>
<style>
    .footer {
        background-color: #f5f5f5 !important;
        color: #3E4885;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        text-align: center;
    }

    .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #f5f5f5;
        height: 70px;
        padding-left: 30px;
        padding-right: calc(30px + (100vw - 100%));
        color: #3E4885;
    }

    .nav-center {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
    }

    .nav-link {
        text-decoration: none;
        color: #3E4885;
        padding: 5px 20px;
        border-radius: 30px;
        margin-left: 65px;
        margin-right: 65px;
        transition: 0.3s ease;
    }

        .nav-link:hover {
            background: #3E4885;
            text-decoration: none;
            color: white;
        }

    .active-cart {
        background: #3E4885;
        border: 2px solid #3E4885;
        transition: 0.3s ease;
    }

    .nav-left h2 {
        margin: 0;
        font-weight: bold;
        font-size: 25px;
    }

    .nav-right {
        flex: 1;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        margin-right: 1px;
        gap: 12px;
    }

    .cart-wrapper, .profile-wrapper {
        position: relative;
        display: inline-block;
        width: 40px;
        height: 40px;
        vertical-align: middle;
        border-radius: 50%;
        overflow: hidden;
        background-color: #3E4885;
    }

    .cart-img, .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
        transition: opacity 0.3s ease;
    }

    .default-img {
        position: relative;
        opacity: 1;
        z-index: 1;
        border: 2px solid #3E4885;
        box-sizing: border-box;
    }

    .nav-icon {
        text-decoration: none;
        font-size: 25px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        transition: 0.3s ease;
    }

        .nav-icon:hover {
            text-decoration: none;
            background: #3E4885;
        }

        .nav-icon img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }

    /* PAGE */
    .cart-container {
        max-width: 1080px;
        margin: 0 auto;
        padding: 36px 28px 80px;
    }

    .cart-title {
        margin-bottom: 28px;
    }

        .cart-title h1 {
            font-size: 40px;
            font-weight: 800;
            color: #3E4885;
            margin: 0 0 4px;
            letter-spacing: -0.5px;
        }

        .cart-title p {
            font-size: 15px;
            color: #3E4885;
            margin: 0;
        }

    /* TWO COLUMN */
    .cart-layout {
        display: grid;
        grid-template-columns: 1fr 330px;
        gap: 22px;
        align-items: start;
    }

    .items-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: #3E4885;
        margin-bottom: 12px;
    }

    /* CART CARDS */
    .cart-items {
        display: flex;
        flex-direction: column;
    }

    .cart-card {
        background: #fff;
        border: 1px solid #7B88B5;
        border-radius: 16px;
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 10px;
        transition: border-color .2s, box-shadow .2s;
    }

        .cart-card:hover {
            border-color: #7B88B5;
            box-shadow: 0 2px 12px rgba(156,175,108,.12);
        }

    .item-left {
        display: flex;
        align-items: center;
        gap: 14px;
        flex: 1;
        min-width: 0;
    }

        .item-left img {
            width: 66px;
            height: 66px;
            object-fit: cover;
            border-radius: 12px;
            border: 1px solid #e2ebd0;
            flex-shrink: 0;
            background: #3E4885;
        }

    .item-info {
        display: flex;
        flex-direction: column;
        gap: 3px;
        min-width: 0;
    }

    .item-name {
        font-size: 15px;
        font-weight: 700;
        color: #1E1E2F;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .item-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .item-tag {
        font-size: 11px;
        padding: 2px 9px;
        border-radius: 20px;
        font-weight: 500;
        background: #F5F7FF;
        color: #1E1E2F;
        border: 1px solid #D6DCFA;
    }

    .item-price-tag {
        font-size: 13px;
        color: #1E1E2F;
        margin-top: 2px;
    }

        .item-price-tag strong {
            color: #3E4885;
            font-weight: 700;
        }

    /* QTY CONTROLS */
    .item-controls {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
    }

    .qty-box {
        display: flex;
        align-items: center;
        border: 1.5px solid #D6DCFA;
        border-radius: 50px;
        overflow: hidden;
        background: #fff;
    }

    .qty-btn {
        width: 36px;
        height: 36px;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 18px;
        font-weight: 600;
        color: #3E4885;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .15s, color .15s;
        flex-shrink: 0;
    }

        .qty-btn:hover {
            background: #f3f8ea;
            color: #3E4885;
        }

        .qty-btn:active {
            transform: scale(.92);
        }

    .qty-count {
        min-width: 34px;
        text-align: center;
        font-size: 14px;
        font-weight: 700;
        color: #3E4885;
    }

    .remove-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1.5px solid #f0e8e8;
        background: none;
        cursor: pointer;
        color: #cca8a8;
        font-size: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .2s;
        flex-shrink: 0;
    }

        .remove-btn:hover {
            color: #e24b4a;
            background: #fff5f5;
            border-color: #f5c8c8;
        }

    /* EMPTY CART */
    .empty-cart {
        background: #fff;
        border: 1px solid #D6DCFA;
        border-radius: 20px;
        padding: 70px 40px;
        text-align: center;
        grid-column: 1 / -1;
        max-width: 500px;
        margin: 0 auto;
        width: 100%;
    }

    .empty-cart-icon {
        width: 80px;
        height: 80px;
        background: #eaf3f8;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 36px;
        border: 2px solid #3E4885;
    }

    .empty-cart h2 {
        font-size: 22px;
        font-weight: 700;
        color: #3E4885;
        margin-bottom: 6px;
    }

    .empty-cart p {
        font-size: 14px;
        color: grey;
        margin: 0;
    }

    .browse-btn {
        margin-top: 24px;
        display: inline-block;
        background: #3E4885;
        color: #fff;
        padding: 13px 30px;
        border-radius: 12px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: .2s;
    }

        .browse-btn:hover {
            background: #fff;
            color: #3E4885;
            border: 1px solid #3E4885;
            text-decoration: none;
            transform: translateY(-1px);
        }

    /* SUMMARY */
    .summary {
        background: #fff;
        border: 1px solid #D6DCFA;
        border-radius: 20px;
        overflow: hidden;
        position: sticky;
        top: 80px;
    }

    .summary-header {
        background: #3E4885;
        padding: 20px 22px;
    }

        .summary-header h3 {
            font-size: 15px;
            font-weight: 700;
            color: #fff;
            margin: 0 0 2px;
        }

        .summary-header p {
            font-size: 12px;
            color: rgba(255,255,255,.75);
            margin: 0;
        }

    .summary-body {
        padding: 18px 22px 22px;
    }

    .summary-items {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 16px;
    }

    .summary-item-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
    }

    .summary-item-name {
        color: #3E4885;
        max-width: 175px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .summary-item-qty {
        font-size: 11px;
        color: #3E4885;
        margin-left: 3px;
    }

    .summary-item-amt {
        font-weight: 600;
        color: #3E4885;
    }

    .summary-divider {
        border: none;
        border-top: 1px solid #3E4885;
        margin: 12px 0;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        color: #3E4885;
        margin-bottom: 6px;
    }

    .summary-total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 12px;
    }

    .summary-total-label {
        font-size: 14px;
        font-weight: 600;
        color: #3E4885;
    }

    .total-price {
        font-size: 22px;
        font-weight: 800;
        color: #3E4885;
        letter-spacing: -0.5px;
    }

    .checkout-btn {
        display: block;
        width: 100%;
        padding: 13px;
        margin-top: 18px;
        background: #3E4885;
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Segoe UI', sans-serif;
        transition: .2s;
    }

        .checkout-btn:hover:not([disabled]) {
            background: #1E1E2F;
            transform: translateY(-1px);
        }

        .checkout-btn[disabled] {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .keep-shopping-btn {
        display: block;
        width: 100%;
        padding: 11px;
        margin-top: 8px;
        background: none;
        border: 1.5px solid #D6DCFA;
        border-radius: 12px;
        color: #3E4885;
        font-size: 13px;
        font-weight: 500;
        text-align: center;
        text-decoration: none;
        transition: .2s;
    }

        .keep-shopping-btn:hover {
            background: #f3f8ea;
            border-color: #3E4885;
            text-decoration: none;
        }
</style>

<div class="cart-container" style="margin-bottom: 5rem;">

    <div class="cart-title">
        <h1>Your Cart</h1>
        <p>Premium compute hardware carefully matched to your workflow requirements.</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning border border-warning-subtle rounded-3 p-3 mb-4 text-dark" style="background-color: #fff3cd; font-size: 14px;">
            ⚠️ <strong>Fulfillment Alert:</strong> @TempData["Error"]
        </div>
    }

    <div class="cart-layout">

        @if (Model == null || !Model.Any())
        {
            <div class="empty-cart">
                <div class="empty-cart-icon">🛒</div>
                <h2>Your cart is empty</h2>
                <p>Looks like you haven't added anything yet.</p>
                <a asp-controller="Store" asp-action="Index" class="browse-btn">Browse Menu</a>
            </div>
        }
        else
        {
            <div>
                <div class="items-label">@Model.Count item@(Model.Count != 1 ? "s" : "") in your cart</div>

                <div class="cart-items">
                    @foreach (var item in Model)
                    {
                        <div class="cart-card">
                            <div class="item-left">
                                <img src="@item.Menu.ImagePath" alt="@item.Menu.Name" />
                                <div class="item-info">
                                    <div class="item-name">@item.Menu.Name</div>
                                    <div class="item-tags">
                                        @if (!string.IsNullOrEmpty(item.Notes))
                                        {
                                            <span class="item-tag">📝 @item.Notes</span>
                                        }
                                    </div>
                                    <div class="item-price-tag">
                                        Variation: <strong>@item.Variation</strong>
                                    </div>
                                    <div class="item-price-tag">
                                        ₱@item.Price.ToString("N2") × @item.Quantity = <strong>₱@item.Total.ToString("N2")</strong>
                                    </div>
                                </div>
                            </div>

                            <div class="item-controls">
                                <form asp-controller="Order" method="post">
                                    <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                                    <div class="qty-box">
                                        <button type="submit" class="qty-btn" formaction="Decrease">−</button>
                                        <span class="qty-count">@item.Quantity</span>
                                        <button type="submit" class="qty-btn" formaction="Increase">+</button>
                                    </div>
                                </form>

                                <form asp-controller="Order" method="post">
                                    <input type="hidden" name="orderItemId" value="@item.OrderItemId" />
                                    <button type="submit" class="remove-btn" formaction="Remove" title="Remove item">🗑️</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="summary">
                <div class="summary-header">
                    <h3>Order Summary</h3>
                    <p>Review your items before checkout</p>
                </div>
                <div class="summary-body">

                    <div class="summary-items">
                        @foreach (var item in Model)
                        {
                            <div class="summary-item-row">
                                <span class="summary-item-name">
                                    @item.Menu.Name
                                    <span class="summary-item-qty">×@item.Quantity</span>
                                </span>
                                <span class="summary-item-amt">₱@item.Total.ToString("N2")</span>
                            </div>
                        }
                    </div>

                    <hr class="summary-divider" />

                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span>₱@subtotal.ToString("N2")</span>
                    </div>
                    <div class="summary-row">
                        <span>Tax (12%)</span>
                        <span>₱@tax.ToString("N2")</span>
                    </div>

                    <hr class="summary-divider" />
                    
                    <div class="summary-total-row">
                        <span class="summary-total-label">Total</span>
                        <span class="total-price">₱@total.ToString("N2")</span>
                    </div>

                    <div class="summary-total-row">
                        <span class="summary-total-label">Your Wallet Balance</span>
                        <span class="total-price bal text-primary">
                            ₱@(((decimal)(ViewBag.UserBalance ?? 0m)).ToString("N2"))
                        </span>
                    </div>

                    <form asp-controller="Order" asp-action="Checkout" method="post">
                        @Html.AntiForgeryToken()
                        @if (ViewBag.IsAmountEnough == false || (ViewBag.UserBalance != null && (decimal)ViewBag.UserBalance < total))
                        {
                            <button type="submit" class="checkout-btn" disabled>
                                Checkout →
                            </button>
                            <p class="text-danger" style="text-align: center; margin-top: 10px; font-size: 13px"><i>Insufficient Balance</i></p>
                        }
                        else
                        {
                            <button type="submit" class="checkout-btn">
                                Checkout →
                            </button>
                        }
                    </form>
                    <a asp-controller="Store" asp-action="Index" class="keep-shopping-btn">
                        Continue Shopping
                    </a>
                </div>
            </div>
        }

    </div>
    <div style="height: 65px; clear: both;"></div>
</div>