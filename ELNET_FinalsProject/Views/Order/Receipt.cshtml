@model ELNET_FinalsProject.Models.Order
@{
    ViewData["Title"] = "Order Confirmed";
    Layout = null; 

    var subtotal = Model.OrderItems.Sum(i => i.Total);
    var tax = subtotal * 0.12m;
    var grandTotal = subtotal + tax;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --primary: #9CAF6C;
            --dark: #5C3D2E;
            --light: #f7f9f2;
            --muted: #8a9e74;
            --border: #c8d9a0;
        }

        body {
            background-color: var(--primary);
            background-image: radial-gradient(circle at 15% 15%, rgba(255,255,255,0.15) 0%, transparent 50%), radial-gradient(circle at 85% 85%, rgba(92,61,46,0.12) 0%, transparent 50%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center; /* changed from flex-start to center */
            padding: 40px 16px;
            font-family: Arial, sans-serif;
        }

        .confirmed-header {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            margin-bottom: 24px;
            animation: fadeInDown 0.5s ease both;
        }

        .check-circle {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            border: 4px solid rgba(255,255,255,0.8);
            background-color: rgba(255,255,255,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 14px;
        }

            .check-circle svg {
                width: 26px;
                height: 26px;
                stroke: #fff;
            }

        .confirmed-header h1 {
            font-size: 30px;
            font-weight: 900;
            color: #fff;
            letter-spacing: -0.5px;
        }

        .confirmed-header p {
            font-size: 13px;
            color: rgba(255,255,255,0.85);
            margin-top: 5px;
        }

        .receipt-card {
            background: #fff;
            border-radius: 20px;
            width: 100%;
            max-width: 370px;
            padding: 24px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.15);
            animation: fadeInUp 0.5s ease both;
        }

        .shop-info {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
        }

        .shop-name {
            font-size: 15px;
            font-weight: 800;
            color: #222;
        }

        .order-number {
            font-size: 11px;
            color: #bbb;
            margin-top: 3px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .order-date {
            text-align: right;
            font-size: 11px;
            color: #bbb;
            line-height: 1.7;
        }

        .order-items {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 20px;
        }

        .order-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .item-img {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            background-color: #f0f4e8;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
            overflow: hidden;
        }

            .item-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 50%;
            }

        .item-details {
            flex: 1;
            min-width: 0;
        }

        .item-name {
            font-size: 13px;
            font-weight: 700;
            color: #222;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .item-desc {
            font-size: 11px;
            color: #bbb;
            margin-top: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .item-price {
            font-size: 13px;
            font-weight: 700;
            color: #333;
            flex-shrink: 0;
        }

        .notch-divider {
            position: relative;
            margin: 20px 0;
        }

            .notch-divider hr {
                border: none;
                border-top: 2px dashed #e0e0e0;
            }

            .notch-divider::before,
            .notch-divider::after {
                content: '';
                position: absolute;
                top: 50%;
                transform: translateY(-50%);
                width: 22px;
                height: 22px;
                background-color: var(--primary);
                border-radius: 50%;
            }

            .notch-divider::before {
                left: -30px;
            }

            .notch-divider::after {
                right: -30px;
            }

        .totals {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 20px;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            color: #888;
        }

            .total-row.grand {
                font-size: 15px;
                font-weight: 800;
                color: #222;
                padding-top: 4px;
            }

        .payment-method {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background-color: #f5f5f5;
            border-radius: 12px;
            padding: 10px 16px;
            margin-bottom: 16px;
        }

            .payment-method svg {
                width: 16px;
                height: 16px;
                stroke: #aaa;
                flex-shrink: 0;
            }

            .payment-method span {
                font-size: 12px;
                color: #888;
            }

        .btn-save {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 13px;
            background-color: #4a5e28;
            color: #fff;
            border: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
            transition: background 0.25s ease;
            margin-bottom: 10px;
        }

            .btn-save:hover {
                background-color: #3a4d1e;
            }

            .btn-save svg {
                width: 16px;
                height: 16px;
                stroke: #fff;
            }

        .btn-back {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 13px;
            background-color: #fff;
            color: #555;
            border: 1.5px solid #e0e0e0;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: background 0.25s ease;
        }

            .btn-back:hover {
                background-color: #f9f9f9;
            }

        @@keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 480px) {
            .receipt-card {
                padding: 20px 18px;
            }

            .confirmed-header h1 {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>

    <div class="confirmed-header">
        <div class="check-circle">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
        </div>
        <h1>Order Confirmed</h1>
        <p>Thank you for your visit to Pickout Cafe!</p>
    </div>

    <div class="receipt-card">

        <div class="shop-info">
            <div>
                <div class="shop-name">Pickout Coffee</div>
                <div class="order-number">ORDER #@Model.OrderId.ToString().PadLeft(5, '0')</div>
            </div>
            <div class="order-date">
                <div>@Model.OrderDate.ToString("MMM dd, yyyy")</div>
                <div>@Model.OrderDate.ToString("hh:mm tt")</div>
            </div>
        </div>

        <div class="order-items">
            @foreach (var item in Model.OrderItems)
            {
                <div class="order-item">
                    <div class="item-img">
                        @if (!string.IsNullOrEmpty(item.Menu?.ImagePath))
                        {
                            <img src="@item.Menu.ImagePath" alt="@item.Menu.Name" />
                        }
                        else
                        {
                            <span>☕</span>
                        }
                    </div>
                    <div class="item-details">
                        <div class="item-name">@item.Menu?.Name</div>
                        <div class="item-desc">
                            @if (item.Quantity > 1)
                            {
                                <span>x@(item.Quantity) · </span>
                            }
                            @item.Menu?.Description
                        </div>
                    </div>
                    <div class="item-price">&#8369;@item.Total.ToString("0.00")</div>
                </div>
            }
        </div>

        <div class="notch-divider">
            <hr />
        </div>

        <div class="totals">
            <div class="total-row">
                <span>Subtotal</span>
                <span>&#8369;@subtotal.ToString("0.00")</span>
            </div>
            <div class="total-row">
                <span>Tax (12%)</span>
                <span>&#8369;@tax.ToString("0.00")</span>
            </div>
            <div class="total-row grand">
                <span>Grand Total</span>
                <span>&#8369;@grandTotal.ToString("0.00")</span>
            </div>
        </div>

        <div class="payment-method">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
        </div>

        <a asp-action="DownloadReceipt" asp-route-id="@Model.OrderId" class="btn-save">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
            </svg>
            Save Receipt
        </a>

        <a asp-action="Index" asp-controller="Store" class="btn-back">
            Back to Home
        </a>

    </div>

</body>
</html>