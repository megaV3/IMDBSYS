@model IMDBSYS.ViewModels.OrderHistoryViewModel

@{
    ViewData["Title"] = "Order History";
}
<!--  For Profile.cshtml designs  -->
@*
    
*@
<link href="~/css/history.css" rel="stylesheet" />

<div class="navbar">
    <div class="nav-left">
        <h2>PICKOUT COFFEE</h2>
    </div>
    <div class="nav-center">
        <a asp-controller="Store" asp-action="Index" class="nav-link active">Home</a>
    </div>
    <div class="nav-right">
        <a asp-controller="Order" asp-action="Cart" style="position:relative; display:inline-block;">
            <!-- Wrap only the images in the circular div -->
            <div class="cart-wrapper">
                <img class="cart-img default-img" src="~/images/cart-grey.png" alt="Cart" />
                <img class="cart-img hover-img" src="~/images/cart-green.png" alt="Cart Hover" />
            </div>

            <!-- Badge stays outside the circular clip -->
            <span id="cart-count" style="
                position: absolute;
                top: 0;
                right: 0;
                font-size: 10px;
                background: #3e4e2c;
                color: white;
                border-radius: 50%;
                padding: 2px 5px;
                line-height: 1;
                transform: translate(25%, -25%);
                z-index: 10;">
                @Model.CartCount
            </span>
        </a>
        <a asp-controller="Identity" asp-action="Profile" class="nav-icon active-profile">
            <img class="nav-icon active-profile" src="@Url.Content(Model.ProfileImagePath)" />
        </a>
    </div>
</div>

<style>
    .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 1000;
        background-color: #f5f5f5;
        height: 70px;
        /*(100vw - 100%) calculates the exact width of the scrollbar dynamically. */
        padding-left: 30px;
        padding-right: calc(30px + (100vw - 100%));
        color: #9caf6c;
    }

    .nav-right {
        flex: 1; /* Takes up 1/3 of space */
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 12px;
    }

    .cart-wrapper, .profile-wrapper {
        position: relative;
        display: flex; /* Changed from inline-block to flex for centering */
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        overflow: hidden;
        margin: 0; /* Let the parent gap handle spacing */
    }

    .cart-img, .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* 'cover' is better for rounded icons to ensure they fill the circle */
        border-radius: 50%; /* Double-ensure the images are rounded */
        transition: opacity 0.3s ease;
    }

    .hover-img {
        position: absolute;
        top: 0;
        left: 0;
        opacity: 0;
        z-index: 2;
    }

    .default-img {
        position: relative;
        opacity: 1;
        z-index: 1;
    }

    /* Hover States */
    .cart-wrapper:hover .hover-img,
    .profile-wrapper:hover .hover-img {
        opacity: 1;
    }

    .cart-wrapper:hover .default-img,
    .profile-wrapper:hover .default-img {
        opacity: 0;
    }

    #cart-count {
        z-index: 10;
        /* Ensure this stays visible even if the wrapper clips images */
    }

    .nav-center {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
    }
</style>


<div class="history-page">

    <div class="history-topbar">

        <div class="history-header">
            <h1>Your Orders</h1>
            <p>Review your previous coffee orders.</p>
        </div>

        <a asp-controller="Identity"
           asp-action="Profile"
           class="back-btn">

            ← Back

        </a>
</div>

    @if (Model.OrderHistory != null && Model.OrderHistory.Any())
    {
        @foreach (var order in Model.OrderHistory)
        {

            <div class="history-card">

                <div class="history-top">
                    <div>
                        <h3>Order ID: @order.OrderId</h3>
                        <span class="date">@order.OrderDate</span>
                    </div>

                    <span class="status completed">
                        @if (order.IsCompleted)
                        {
                            <span class="">Completed</span>
                        }
                        else
                        {
                            <span class="text-bg-secondary">Not Completed</span>
                        }
                    </span>

                </div>

                <div class="history-middle mb-4">
                    <p><bold>Customer</bold>: @order.CustomerName</p>
                    <hr />
                    
                    Orders:
                    @foreach (var orderItem in order.OrderItems)
                    {
                        <div class="row">
                            <div class="col-5">
                                <span>
                                    x @orderItem.Quantity - <strong> @orderItem.Menu.Name</strong> <small> <br />
                                    (Note:
                                    @if (orderItem.Notes != null)
                                    {
                                        @orderItem.Notes
                                    } else {
                                        <span>None</span>
                                    }
                                    ) </small>
                                
                                </span>
                            </div>
                            <div class="col-2">
                                <small class="fst-italic">@orderItem.Quantity x @orderItem.Price -  ₱ @(orderItem.Price * orderItem.Quantity)</small>
                            </div>
                        </div>
                    }
                </div>

                <div class="history-bottom">
                    <h2>Total: ₱ @order.TotalAmount</h2>
                </div>

            </div>
        }
        
    } else
    {
        
        <div style="text-align:center; padding:40px 0; color:#aaa;">
            <div style="font-size:40px; margin-bottom:10px;">🧾</div>
            <p style="margin:0; font-size:14px;">No orders yet.</p>
        </div>
    }
