@{
    Layout = null; // Forces this layout to be independent from the global user storefront layout
    
    // Retrieve the active action name from the current route context
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IMDBSYS Admin</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    
    <style>
            /* Prevent the entire viewport window from bouncing or shifting horizontally */
            html, body {
                margin: 0;
                padding: 0;
                width: 100% !important;
                height: 100%;
                background-color: #f8f9fa;
                overflow-x: hidden !important;
            }

            /* THE SYSTEM-WIDE STRUCTURAL LOCKDOWN */
            .admin-wrapper {
                display: grid; /* Enforce rigid CSS Grid instead of fluid flexbox layout */
                grid-template-columns: 250px 1fr; /* Sidebar is exactly 250px, Content gets exactly the remaining space */
                width: 100vw;
                height: 100vh;
                overflow: hidden;
            }

            .admin-sidebar {
                background-color: #212529;
                height: 100vh;
                display: flex;
                flex-direction: column;
                width: 250px !important;
            }

            .admin-content {
                padding: 24px;
                height: 100vh;
                overflow-y: auto;
                box-sizing: border-box !important;
                width: 100% !important; /* Forces the content viewport container to never stretch */
            }

                /* NEUTRALIZE BOOTSTRAP NEGATIVE MARGIN BLEED SYSTEM-WIDE */
                .admin-content .row {
                    margin-left: 0 !important;
                    margin-right: 0 !important;
                    width: 100% !important;
                }

            .sidebar-link {
                transition: background-color 0.2s ease-in-out;
                color: rgba(255,255,255,0.85) !important;
                text-decoration: none;
            }

                .sidebar-link:hover {
                    background-color: rgba(255,255,255,0.1);
                    color: #fff !important;
                }

                .sidebar-link.active {
                    background-color: #0d6efd !important;
                    color: #fff !important;
                }
    </style>
</head>
<body>

    <div class="admin-wrapper">
        <div class="admin-sidebar d-flex flex-column flex-shrink-0 p-3 text-white bg-dark">
            <a asp-controller="Admin" asp-action="Dashboard" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
                <span class="fs-4 fw-bold">Admin Controls</span>
            </a>
            <hr>
    
            <ul class="nav nav-pills flex-column mb-auto gap-1">
                <li class="nav-item">
                    <a asp-controller="Admin" asp-action="Dashboard"
                           class="nav-link sidebar-link @(currentAction == "Dashboard" ? "active" : "")">
                        📊 Dashboard
                    </a>
                </li>
                <li>
                    <a asp-controller="Admin" asp-action="MenuIndex"
                           class="nav-link sidebar-link @(currentAction == "MenuIndex" ? "active" : "")">
                        🍔 Products / Menu
                    </a>
                </li>
                <li>
                    <a asp-controller="Admin" asp-action="OrderRegistry"
                           class="nav-link sidebar-link @(currentAction == "OrderRegistry" ? "active" : "")">
                        🛒 Order Registry
                    </a>
                </li>
        
                <li>
                    <a asp-controller="Admin" asp-action="RequestRestock"
                           class="nav-link sidebar-link @(currentAction == "RequestRestock" ? "active" : "")">
                        🚚 Request Product Restock
                    </a>
                </li>
                <li>
                    <a asp-controller="Admin" asp-action="RestockLedger"
                           class="nav-link sidebar-link @(currentAction == "RestockLedger" ? "active" : "")">
                        📑 Product Restocks
                    </a>
                </li>
        
                <li>
                    <a asp-controller="Admin" asp-action="TopUpLedger"
                           class="nav-link sidebar-link @(currentAction == "TopUpLedger" ? "active" : "")">
                        💳 Wallet Top-Ups
                    </a>
                </li>
                <li>
                    <a asp-controller="Admin" asp-action="UserManagement"
                           class="nav-link sidebar-link @(currentAction == "UserManagement" ? "active" : "")">
                        👥 User Management
                    </a>
                </li>
            </ul>
    
            <hr />

            <div class="dropdown">
                <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-2" style="width: 32px; height: 32px; font-size: 14px;">
                        AD
                    </div>
                    <strong>System Admin</strong>
                </a>
                <ul class="dropdown-menu dropdown-menu-dark text-small shadow border-secondary" aria-labelledby="dropdownUser1">
                    <li>
                        <a class="dropdown-item py-2" asp-controller="Admin" asp-action="ProfileDetails">
                            👤 My Profile
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-2" asp-controller="Admin" asp-action="SecuritySettings">
                            ⚙️ Account Settings
                        </a>
                    </li>
                    <li><hr class="dropdown-divider border-secondary"></li>
                    <li>
                        <form asp-controller="Admin" asp-action="Logout" method="post" class="d-inline w-100">
                            <button type="submit" class="dropdown-item py-2 text-danger fw-bold btn btn-link text-start w-100" style="text-decoration: none; box-shadow: none;">
                                🚪 Log Out
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>

        <div class="admin-content">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>