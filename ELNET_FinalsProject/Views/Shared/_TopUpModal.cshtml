<style>
    .payment-card{
        border: 1px solid black;
        border-radius:4px;
        margin-right:40px;
    }

    .payment-container{
        flex-wrap:wrap;
        gap:10px;
    } 

    .modal-input {
        width: 90% !important;
        padding: 17px !important; /* top-bottom | left-right */
        border: 1px solid #3e4e2c !important;
        border-radius: 10px !important;
        font-size: 15px !important;
    }

    .modal-header-custom{
        background-color: #6B8E23; /* green */
        padding: 10px 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: -30px -30px 20px -30px;
        border-radius: 20px 20px 0 0;
        }

    .modal-header-custom h3{
        margin: 0;
        color: white;
        font-size: 30px;
        font-weight: bold;
    }

    .close-custom{
        background: none;
        border: none;
        color: white;
        font-size: 35px;
        cursor: pointer;
    }

</style>

@model ELNET_FinalsProject.ViewModels.TopUpViewModel

<div id="topUpOverlay" class="custom-modal-overlay" onclick="handleTopUpOverlayClick(event)">
    <div id="topUpModal" class="custom-modal-content">

        <div class="modal-header-custom">
            <h3>Top Up Balance</h3>
            <button type="button" class="close-custom" onclick="closeTopUpModal()">×</button>
        </div>

        <form asp-action="ProcessTopUp" asp-controller="Identity" method="post" style="margin: 0;">
            <div class="modal-body-custom">
                <label style="color: #333; font-weight: bold; display: block; margin-bottom: 10px;">Amount to Add</label>
                <input asp-for="Amount" class="modal-input" placeholder="₱0.00" required />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="modal-body-custom">
                <label style="color: #333; font-weight: bold; display: block; margin-bottom: 10px;">Email</label>
                <input asp-for="Email" class="modal-input" value="@Model.Email" readonly />
            </div>

            <div class="modal-body-custom">
                <label style="color: #333; font-weight: bold; display: block; margin-bottom: 10px;">Payment Method</label>
                @* <input asp-for="PaymentMethod" class="modal-input" /> *@
                <span asp-validation-for="PaymentMethod" class="text-danger"></span>

                <div class="payment-container" style="display:flex; justify-content:center; align-items:center;">
                    <div class="payment-card">
                        <label>
                            <input type="radio" asp-for="PaymentMethod" value="Gcash">
                            <img src="coffee.jpg" alt="Coffee"> <!--Gcashi-->
                        </label>
                    </div>

                    <div class="payment-card">
                        <label>
                            <input type="radio" asp-for="PaymentMethod" value="PayMaya">
                            <img src="coffee.jpg" alt="Coffee"> <!--Paymaya-->
                        </label>
                    </div>
                    
                    <div class="payment-card">
                        <label>
                            <input type="radio" asp-for="PaymentMethod" value="GoTyme">
                            <img src="coffee.jpg" alt="Coffee"> <!--GoTyme-->
                        </label>
                    </div>

                    <div class="payment-card">
                        <label>
                            <input type="radio" asp-for="PaymentMethod" value="Credit Card">
                            <img src="coffee.jpg" alt="Coffee"> <!--Credit Cards and Sh-->
                        </label>
                    </div>
                </div>

            </div>

            <div class="modal-footer-custom">
                <button type="button" class="btn-cancel-custom" onclick="closeTopUpModal()">Close</button>
                <button type="submit" class="btn-confirm-custom">Confirm</button>
            </div>
        </form>
    </div>
</div>