@{
    ViewData["Title"] = "Home";
}

<!-- top sec -->
<div class="top-section">
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">PICKOUT HARDWARE</div>
            <ul class="nav-links " style="margin: auto 0">   
                <li>
                    <a asp-controller="Identity" asp-action="Login">Log In</a>
                </li>  
                <li>
                    <a asp-controller="Identity" asp-action="CreateAccount">Sign Up</a>
                </li>  
            </ul>  
        </div>  
    </nav>  

    <div class="hero-wrapper">  
        <div class="hero">  
            <div class="hero-text">  
             <h1>PICKOUT HARDWARE</h1>  
                <p>                   Everything you need for your digital workspace and gaming setup.
                </p>  
            </div>  
        
            <!-- carousel -->
            <div class="hero-image">
                <div id="coffeeCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <img src="~/images/pc_setup.jpg" class="d-block w-100" alt="PC Set-up">
                        </div>
                        <div class="carousel-item">
                            <img src="~/images/p_setup2.jpg" class="d-block w-100" alt="Laptop">
                        </div>
                        <div class="carousel-item">
                            <img src="~/images/pc_setup1.jpg" class="d-block w-100" alt="PC Set-up">
                        </div>
                        <div class="carousel-item">
                            <img src="~/images/pp_setup3.jpg" class="d-block w-100" alt="Printer">
                        </div>
                    </div>  
                </div>
            </div>  
        </div>  
    </div>
</div>

<!-- bottom sec and shi -->
<div class="bottom-section">
    <div class="drinks-menu">
        <h2>OUR SIGNATURES</h2>
        <div class="drinks-grid">

            <!-- card 1 - biscoff -->
            <div class="drink-card">
                <img src="~/images/signatures/kape kastila.png" alt="Kape Kastila" class="drink-image">
                <h3>Kape Kastila</h3>
            </div>

            <!-- card 2 - strawberry -->
            <div class="drink-card">
                <img src="~/images/signatures/iced white mocha latte.png" alt="Iced White Mocha Latte" class="drink-image">
                <h3>Iced White Mocha Latte <span class="new-badge">NEW!</span></h3>
            </div>

            <!-- card 3 - chocolate -->
            <div class="drink-card">
                <img src="~/images/signatures/iced caramel macchiato.png" alt="Iced Caramel Macchiato" class="drink-image">
                <h3>Iced Caramel Macchiato</h3>
            </div>

            <!-- card 4 - matcha -->
            <div class="drink-card">
                <img src="~/images/signatures/pickup creme latte.png" alt="Pickup Creme Latte" class="drink-image">
                <h3>Pickup Crème Latte</h3>
            </div>

            @* <!-- card 5 - caramel -->
            <div class="drink-card">
                    <img src="~/images/frappes/caramel.png" alt="Caramel" class="drink-image">
                <h3>Salted Caramel Frappe</h3>
            </div> *@
        </div>

        <div class="motto">
                <h3>Freshly Brewed, Fast Pickout</h3>
                 <p>Made with premium beans</p>
        </div>
    </div>
</div>



<!-- Our Story -->
<div class="story-section">
    <div class="story-container">
        <div class="story-content">
            <h2>Our Story</h2>
            
            <p>It started with a simple problem—finding a café that truly fits student life.</p>
            
            <p>The Powerpuff Gals, a group of five friends, were constantly juggling classes, deadlines, and coffee runs. But every café felt lacking—too noisy, too slow, or simply not made for their kind of routine.</p>
            
            <p>So they created their own.</p>
            
            <p>Each friend contributed something unique—from crafting a cozy, aesthetic space to keeping things organized and ensuring comfort and creativity. Together, they built more than a café—they created a space where people can focus, relax, and feel at home.</p>
            
            <p>A place for calm mornings, productive afternoons, and lighter nights—with a good cup of coffee in hand.</p>
            
            <p class="story-ending">At its heart, it's simple:<br> <strong>good coffee, good company, and a place that feels right.</strong></p>
        </div>
    </div>
</div>