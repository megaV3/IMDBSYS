<!-- For Store's Index.cshtml design -->
<link href="~/css/storeindex.css" rel="stylesheet" />
<div class="navbar">
    <div class="nav-left">
        <h2>PICKOUT COFFEE</h2>
    </div>
    <div class="nav-center">
        <a asp-controller="Store" asp-action="Index" class="nav-link active">Home</a>
    </div>
    <div class="nav-right">
        <div class="nav-balance">
            <span class="balance-label">₱</span>
            <span class="balance-amount">@Model.UserProfile.Balance.ToString("0.00")</span>
        </div>
        
        <a asp-controller="Order" asp-action="Cart" class="nav-icon">
            🛒
            <span id="cart-count" style="
                position: absolute;
                top: 0;
                right: 0;
                font-size: 10px;
                background: #3e4e2c;
                color: white;
                border-radius: 50%;
                padding: 2px 5px;
                line-height: 1;
                transform: translate(25%, -25%);">
                @Model.CartCount
