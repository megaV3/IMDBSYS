<div id="basketOverlay" onclick="handleOverlayClick(event)">
    <div id="basketModal">

        <div id="bModalImgWrap">☕</div>

        <div class="modal-body">

            <div class="modal-row-header">
                <div id="bModalName"></div>
                <div id="bModalPrice"></div>
            </div>
            <p id="bModalDesc"></p>

            <div id="variationLabel" class="modal-section-label">Variation</div>
            <div id="variationContainer" class="temp-row">
            </div>

            <div style="display:none;">
                <button id="btnHot"></button>
                <button id="btnIced"></button>
            </div>
            <div class="modal-section-label">Quantity</div>
            <div class="qty-wrapper">
                <div class="qty-row">
                    <button class="qty-btn" onclick="changeQty(-1)">−</button>
                    <span id="bQtyVal">1</span>
                    <button class="qty-btn" onclick="changeQty(1)">+</button>
                </div>
                <span id="bSubtotal"></span>
            </div>


            <div class="modal-section-label">Special Instructions</div>
            <textarea id="bNotes" rows="2" placeholder="e.g. Partitioning requests, gift wrapping, etc..."></textarea>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeBasketModal()">Cancel</button>
                <button class="btn-add-confirm" onclick="submitBasket()">Add to Basket</button>
            </div>

        </div>
    </div>
</div>

<div id="bToast"></div>

<iframe name="hidden_iframe" id="hidden_iframe" style="display:none;"></iframe>

<script>
    const variationsMap = {
        "StorageDevices": [
            { spec: "256GB", add: 0 },
            { spec: "512GB", add: 500 },
            { spec: "1TB", add: 1500 },
            { spec: "2TB", add: 3500 }
        ],
        "RAM": [
            { spec: "8GB", add: 0 },
            { spec: "16GB", add: 1200 },
            { spec: "32GB", add: 2500 }
        ]
    };
    var _selectedVariation = ""; // Replace _temp
    var _basePrice = 0;
    var _currentAddon = 0;

    var _menuId, _price, _qty = 1, _temp = 'Iced';
    function openBasketModal(menuId, name, price, desc, imgPath, canBeHot, canBeCold, category) {
        _menuId = menuId;
        _basePrice = price;
        _qty = 1;
        _currentAddon = 0;

        // Reset Modal content
        document.getElementById('bModalName').textContent = name;
        document.getElementById('bModalPrice').textContent = 'PHP ' + price;
        document.getElementById('bModalDesc').textContent = desc;

        // Handle Variations dynamically
        const container = document.getElementById('variationContainer');
        if (!container) {
            console.error("variationContainer not found!");
            return;
        }
        container.innerHTML = "";

        // Determine which options to show
        let options = variationsMap[category] || [{ spec: "Standard", add: 0 }];

        // Set initial selection
        _selectedVariation = options[0].spec;
        _currentAddon = options[0].add;

        // Create buttons
        options.forEach(opt => {
            const btn = document.createElement('button');
            btn.className = 'temp-btn' + (opt.spec === _selectedVariation ? ' active' : '');
            btn.textContent = opt.spec + (opt.add > 0 ? " (+₱" + opt.add + ")" : "");
    
            btn.onclick = function() {
                _selectedVariation = opt.spec;
                _currentAddon = opt.add;
        
                // UI Toggle
                container.querySelectorAll('.temp-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
        
                updateSubtotal();
            };
            container.appendChild(btn);
        });

        // --- Image Handling ---
        var wrap = document.getElementById('bModalImgWrap');
        if (imgPath && imgPath.trim() !== '' && imgPath.trim() !== 'null') {
            wrap.innerHTML = '<img src="' + imgPath + '" alt="' + name + '" style="width:100%; height:100%; object-fit:cover; border-radius:12px;" />';
        } else {
            wrap.innerHTML = '<span style="font-size: 50px;">🖥️</span>';
        }

        // --- Quantity & UI Reset ---
        document.getElementById('bQtyVal').textContent = _qty;
        document.getElementById('bNotes').value = '';
        document.querySelectorAll('.allergy-chip').forEach(function(c) {
            c.classList.remove('active');
        });

        // --- Final Display ---
        updateSubtotal();
        document.getElementById('basketOverlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    function updateSubtotal() {
        let totalUnit = _basePrice + _currentAddon;
        document.getElementById('bSubtotal').textContent = '= PHP ' + (totalUnit * _qty).toLocaleString();
    }
    function submitBasket() {
        var chips = [];
        document.querySelectorAll('.allergy-chip.active').forEach(function(c) {
            chips.push(c.textContent);
        });
        var freeText = document.getElementById('bNotes').value.trim();
        var parts = chips.join(', ');
        var notes = (parts && freeText) ? (parts + ' | ' + freeText) : (parts || freeText);

        fetch('/Order/AddToCart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'menuId='       + encodeURIComponent(_menuId)
                + '&quantity='    + encodeURIComponent(_qty)
                + '&variation='   + encodeURIComponent(_selectedVariation) // CHANGED FROM TEMPERATURE
                + '&notes='       + encodeURIComponent(notes)
                + '&price=' + (_basePrice + _currentAddon)
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                closeBasketModal();
                updateCartCount(_qty);
                showToast('Added ' + _qty + ' to basket!');
            }
        });
    }

