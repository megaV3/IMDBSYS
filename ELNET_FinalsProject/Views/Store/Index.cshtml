<style>
    .navbar {
        display: flex;
        justify-content: space-between;
        position: sticky; /*sticks to one place whenever you scroll*/
        top: 0;           /*sticks at the top*/
        z-index: 100;     /*ensures that it stays above other content*/
        background-color: #f5f5f5;
        
        padding: 10px 30px;
        color: #9caf6c;
    }

    .nav-center {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
    }


    .nav-left h2 {
        margin: 0;
        font-weight: bold;
        font-size: 25px;
    }

    .nav-right {
        display: flex;
        gap: 20px;
    }

    /* .nav-icon {
        text-decoration: none;
        font-size: 25px;

        display:inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;

        border-radius: 50%;
        transition: 0.3s ease;
    } */

    .nav-icon {
        text-decoration: none;
        font-size: 25px;
        /* These 3 lines center the 🛒 perfectly */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        /* This is the secret: it keeps the bubble relative to the icon */
        position: relative;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        transition: 0.3s ease;
    }

        .nav-icon:hover {
            text-decoration: none;
            background: #9caf6c;
            color: white; /* Optional: makes the cart white on hover */
        }

    .nav-icon:hover {
        text-decoration: none;
        background: #9caf6c;
    }

