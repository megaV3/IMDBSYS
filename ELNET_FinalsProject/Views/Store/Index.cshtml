@* scrollspy *@
<script>

        const observerOptions = {
        root: null,
        rootMargin: '-15% 0px -75% 0px', // Adjusts the "trigger" area in the viewport
        threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const id = entry.target.getAttribute('id');

                // Remove active class from all buttons
                document.querySelectorAll('.quick-btn').forEach(btn => {
                    btn.classList.remove('active-menu');
                });

                // Add active class to the matching link
                const activeLink = document.querySelector(`.quick-btn[href="#${id}"]`);
                if (activeLink) {
                    activeLink.classList.add('active-menu');
                }
            }
        });
    }, observerOptions);

    // Track all sections that have an ID corresponding to a menu link
    document.querySelectorAll('section[id], div[id]').forEach((section) => {
        observer.observe(section);
    });
</script>

<script>
    // for search bar
        document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById('menuSearch');
        const resultsDiv = document.getElementById('searchResults');
    
        // Get all product titles from your cards
        const cards = document.querySelectorAll('.card');

        searchInput.addEventListener('input', function () {
            const query = this.value.toLowerCase();
            resultsDiv.innerHTML = ''; // Clear previous results

            if (query.length < 1) {
                resultsDiv.style.display = 'none';
                return;
            }

            let foundMatch = false;

            cards.forEach(card => {
                const title = card.querySelector('.card-title').innerText;
            
                if (title.toLowerCase().includes(query)) {
                    foundMatch = true;
                    const item = document.createElement('div');
                    item.className = 'search-item';
                    item.innerText = title;

                    // When clicked, scroll to that specific card
                    item.onclick = function () {
                        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    
                        // Optional: Brief highlight effect so the user sees which one it is
                        card.style.transition = "0.5s";
                        card.style.boxShadow = "0 0 20px #3E4885";
                        setTimeout(() => { card.style.boxShadow = ""; }, 2000);

                        resultsDiv.style.display = 'none';
                        searchInput.value = title;
                    };
                    resultsDiv.appendChild(item);
                }
            });

            if (!foundMatch) {
                const noResult = document.createElement('div');
                noResult.className = 'search-item no-result';
                noResult.innerText = 'No match found';
                noResult.style.color = '#999';
                noResult.style.cursor = 'default';

                resultsDiv.appendChild(noResult);
            }

            resultsDiv.style.display = 'block';
        });

        searchInput.addEventListener('keypress', function (e) {

        if (e.key === 'Enter') {

            const query = this.value.toLowerCase();

            cards.forEach(card => {

                const title = card.querySelector('.card-title').innerText;

                if (title.toLowerCase() === query) {

                    card.scrollIntoView({
                        behavior: 'smooth',
                        block: 'center'
                    });

                    card.style.transition = "0.5s";
                    card.style.boxShadow = "0 0 20px #3E4885";

                    setTimeout(() => {
                        card.style.boxShadow = "";
                    }, 2000);

                    resultsDiv.style.display = 'none';
                }
            });
        }
    });


        // Close dropdown if user clicks away
        document.addEventListener('click', (e) => {
            if (
                !searchInput.contains(e.target) &&
                !resultsDiv.contains(e.target)
            ) {
                resultsDiv.style.display = 'none';
            }
        });
    });
</script>

