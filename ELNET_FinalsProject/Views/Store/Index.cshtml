@{
}
<div class ="navbar">

    <div class="nav-left">
        <h2>PICKOUT COFFEE</h2>
    </div>

    <div class="nav-center">
        <a asp-controller="Store" asp-action="Index" class="nav-link active">Home</a>
    </div>

    <div class="nav-right">
        <a asp-controller="Cart" asp-action="Index" class="nav-icon">
            🛒
        </a>

        <a asp-controller="Profile" asp-action="Index" class="nav-icon">
            👤
        </a>
    </div>

</div>
<style>
    .navbar {
        display: flex;
        justify-content: space-between;

        padding: 10px 30px;
        color: #9caf6c;
    }

    .nav-center {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
    }


    .nav-left h2 {
        margin: 0;
        font-size: 25px;
    }

    .nav-right {
        display: flex;
        gap: 20px;
    }

    .nav-icon {
        text-decoration: none;
        font-size: 25px;

        display:inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;

        border-radius: 50%;
        transition: 0.3s ease;
    }

    .nav-icon:hover {
        text-decoration: none;
        background: #9caf6c;
    }

    body {
        background-color: #f5f5f5;
        font-family: Arial, sans-serif;
    }

    .header {
        text-align: center;
        margin-bottom: 70px;
        color: #9caf6c;
    }

    .header h2 {
        font-size: 26px;

    }

    .menu-header h1 {
        text-align: center;
        color: #3e4e2c;
    }

    .big-title {
    text-align: center;
    margin-bottom: 30px;
    }

    .big-title h1 {
    font-size: 100px;
    font-weight: 900;
    color: #9caf6c;
    letter-spacing: 5px;
    text-shadow: 4px 4px 10px rgba(0,0,0,0.2);
    }

    .row-fluid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 30px;
        margin-top: 30px; /* ⬅️ space from header */
    }

    .card {
        width: 350px;
        padding: 15px;
        border-radius: 15px;
        background: white;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        text-align: center;
    }

    .card:hover {
        background-color: #9caf6c;
        color: white;

    }

    .card:hover .btn-cart {
        background-color: #f5f5f5;
        color: #9caf6c;

    }

    img {
        height: 280px;
        width: 100%;
        object-fit: cover;
        border-radius: 10px;
    }

    .card-title {
        font-size: 18px;
        font-weight: bold;
        color: #3e4e2c;
    }

    .card-text {
        font-size: 15px;
    }

    .card-subtitle {
        font-weight: bold;
        color: #6f4e37;
    }

    .btn-cart {
        font-weight: bold;
        background-color: #9caf6c;
        color: white;
        border: none;
        padding: 6px 10px;
        border-radius: 8px;
        margin-top: 8px;
        cursor: pointer;
    }

    .btn-cart:hover {
            background-color: #f5f5f5;
     }
</style>

@if (!User.Identity.IsAuthenticated)
{
    <a asp-controller="Auth" asp-action="Login">Login</a>
}

<div class="header">
    <h2>Welcome to the Pickup Coffee store page!</h2>
    <h5>Enjoy your shopping experience, @User.Identity.Name!</h5>
</div>

<div class="menu">

    <div class="menu-header big-title">
        <h1>OUR MENU</h1>
    </div>

    <div class="signatures-header">
        <h2 class="mt-5">⋆.𐙚 ̊  SIGNATURES ̊  𐙚.⋆</h2>
    </div>

    <div class="row-fluid">

        <!-- ITEM -->
        <div class="card">
            <img src="~/images/kape kastila.png" />
            <div class="card-body">
                <h5 class="card-title">Kape Kastila</h5>
                <p class="card-text">Leche condensada with creamy milk and espresso.</p>
                <p class="card-subtitle">PHP 75</p>
                <button class="btn-cart">Add to Cart 🛒</button>
            </div>
        </div>

        <!-- ITEM -->
        <div class="card">
            <img src="~/images/iced white mocha latte.png" />
            <div class="card-body">
                <h5 class="card-title">Iced White Mocha Latte</h5>
                <p class="card-text">White chocolate with creamy milk and espresso.</p>
                <p class="card-subtitle">PHP 89</p>
                <button class="btn-cart">Add to Cart 🛒</button>
            </div>
        </div>

        <!-- ITEM -->
        <div class="card">
            <img src="~/images/iced caramel macchiato.png" />
            <div class="card-body">
                <h5 class="card-title">Iced Caramel Macchiato</h5>
                <p class="card-text">Rich espresso with milk and caramel.</p>
                <p class="card-subtitle">PHP 89</p>
                <button class="btn-cart">Add to Cart 🛒</button>
            </div>
        </div>

    </div>

    <div class="espresso-header">
        <h2 class="mt-5">⋆.𐙚 ̊  ESPRESSO-BASED ̊  𐙚.⋆</h2>
    </div>

    <div class="row-fluid">

        <div class="card">
            <img src="~/images/cappuccino.png" />
            <div class="card-body">
                <h5 class="card-title">Cappuccino</h5>
                <p class="card-text">Rich espresso with milk and foam.</p>
                <p class="card-subtitle">PHP 75</p>
                <button class="btn-cart">Add to Cart 🛒</button>
            </div>
        </div>

        <div class="card">
            <img src="~/images/iced brown sugar latte.png" />
            <div class="card-body">
                <h5 class="card-title">Iced Brown Sugar Latte</h5>
                <p class="card-text">Espresso with milk and brown sugar.</p>
                <p class="card-subtitle">PHP 79</p>
                <button class="btn-cart">Add to Cart 🛒</button>
            </div>
        </div>

        <div class="card">
            <img src="~/images/sea salt biscoff latte.png" />
            <div class="card-body">
                <h5 class="card-title">Sea Salt Biscoff Latte</h5>
                <p class="card-text">Espresso with milk and biscoff.</p>
                <p class="card-subtitle">PHP 115</p>
                <button class="btn-cart">Add to Cart 🛒</button>
            </div>
        </div>

    </div>

</div>