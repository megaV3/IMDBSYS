        }
    </div>
    <!-- Profile Modal Overlay -->
    <div id="profileModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:9999; align-items:center; justify-content:center;">
        <div style="background:white; border-radius:22px; padding:36px 40px 32px; width:100%; max-width:440px; display:flex; flex-direction:column; align-items:center; position:relative;">

            <!-- Close button -->
            <button onclick="closeProfile()" style="position:absolute; top:14px; right:18px; background:none; border:none; font-size:20px; cursor:pointer; color:#7a7a6a;">✕</button>

            <!-- Avatar -->
            <div style="position:relative; margin-bottom:16px;">
                <div id="avatarDisplay" style="width:84px; height:84px; border-radius:50%; border:3px solid #9aad78; background:#2d3e4f; color:white; display:flex; align-items:center; justify-content:center; font-size:26px; font-weight:600; overflow:hidden;">
                    <span id="avatarInitials"></span>
                    <img id="avatarImg" src="" style="display:none; width:100%; height:100%; object-fit:cover;" />
                </div>
                <button type="button" onclick="document.getElementById('imageUpload').click()"
                        style="position:absolute; bottom:2px; right:2px; width:26px; height:26px; border-radius:50%; background:#5a6b40; border:2px solid white; cursor:pointer; display:flex; align-items:center; justify-content:center; padding:0;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                        <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                        <circle cx="12" cy="13" r="4" />
                    </svg>
                </button>
            </div>

            <p style="color:#5a6b40; font-size:16px; font-weight:600; margin-bottom:4px;">Your Profile</p>
            <p style="color:#7a7a6a; font-size:12px; margin-bottom:20px; text-align:center;">Update your details for a personalized brew experience.</p>

            <div id="successMsg" style="display:none; background:#eaf3de; color:#3b6d11; border-radius:10px; padding:8px 16px; font-size:13px; margin-bottom:14px; width:100%; text-align:center;"></div>

            <form id="profileForm" method="post" enctype="multipart/form-data" style="width:100%;">
                @Html.AntiForgeryToken()
                <input type="file" id="imageUpload" name="ProfileImage" accept="image/*" style="display:none" onchange="previewImage(this)" />

                <div style="margin-bottom:14px;">
                    <label style="font-size:10px; letter-spacing:0.1em; color:#7a7a6a; font-weight:700; display:block; margin-bottom:5px; text-transform:uppercase;">First Name</label>
                    <div style="position:relative;">
                        <input id="inputFirstName" name="FirstName" type="text" style="width:100%; background:#f6f8f2; border:1.5px solid #c8d4b0; border-radius:50px; padding:11px 42px 11px 18px; font-size:14px; outline:none;" />
                        <span style="position:absolute; right:15px; top:50%; transform:translateY(-50%); color:#9a9a8a;">✏️</span>
                    </div>
                </div>

                <div style="margin-bottom:14px;">
                    <label style="font-size:10px; letter-spacing:0.1em; color:#7a7a6a; font-weight:700; display:block; margin-bottom:5px; text-transform:uppercase;">Last Name</label>
                    <div style="position:relative;">
                        <input id="inputLastName" name="LastName" type="text" style="width:100%; background:#f6f8f2; border:1.5px solid #c8d4b0; border-radius:50px; padding:11px 42px 11px 18px; font-size:14px; outline:none;" />
                        <span style="position:absolute; right:15px; top:50%; transform:translateY(-50%); color:#9a9a8a;">✏️</span>
                    </div>
                </div>

                <div style="margin-bottom:20px;">
                    <label style="font-size:10px; letter-spacing:0.1em; color:#7a7a6a; font-weight:700; display:block; margin-bottom:5px; text-transform:uppercase;">Email Address</label>
                    <div style="position:relative;">
                        <input id="inputEmail" name="Email" type="email" readonly style="width:100%; background:#f6f8f2; border:1.5px solid #c8d4b0; border-radius:50px; padding:11px 42px 11px 18px; font-size:14px; outline:none; opacity:0.55; cursor:not-allowed;" />
                        <span style="position:absolute; right:15px; top:50%; transform:translateY(-50%); color:#9a9a8a;">✉️</span>
                    </div>
                </div>

                <button type="button" onclick="saveProfile()"
                        style="width:100%; background:#5a6b40; color:white; border:none; border-radius:50px; padding:13px; font-size:14px; cursor:pointer; margin-bottom:14px; font-weight:500;">
                    Save Changes
                </button>
            </form>

            <a href="/Identity/Logout" style="color:#c0392b; font-size:13px; text-decoration:none;">Sign Out</a>
        </div>
    </div>
</div>
<script>
    function openProfile() {
        // Fetch current user profile data
        fetch('/Identity/GetProfile')
            .then(res => res.json())
            .then(data => {
                document.getElementById('inputFirstName').value = data.firstName;
                document.getElementById('inputLastName').value = data.lastName;
                document.getElementById('inputEmail').value = data.email;

                // Set avatar
                if (data.profileImagePath) {
                    document.getElementById('avatarImg').src = data.profileImagePath;
                    document.getElementById('avatarImg').style.display = 'block';
                    document.getElementById('avatarInitials').style.display = 'none';
                } else {
                    document.getElementById('avatarInitials').textContent =
                        data.firstName.charAt(0) + data.lastName.charAt(0);
                    document.getElementById('avatarImg').style.display = 'none';
                    document.getElementById('avatarInitials').style.display = 'block';
                }

                document.getElementById('profileModal').style.display = 'flex';
            });
    }

    function closeProfile() {
        document.getElementById('profileModal').style.display = 'none';
    }

    // Close modal if clicking outside the card
    document.getElementById('profileModal').addEventListener('click', function(e) {
        if (e.target === this) closeProfile();
    });

    function previewImage(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('avatarImg').src = e.target.result;
                document.getElementById('avatarImg').style.display = 'block';
                document.getElementById('avatarInitials').style.display = 'none';
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function saveProfile() {
        const form = document.getElementById('profileForm');
        const formData = new FormData(form);

        fetch('/Identity/ProfileAjax', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                const msg = document.getElementById('successMsg');
                msg.textContent = 'Profile updated successfully!';
                msg.style.display = 'block';
                setTimeout(() => msg.style.display = 'none', 3000);
            }
        });
    }
</script>

<script>
    function updateCartCount() {
        // 1. Find the span element by its ID
        var countElement = document.getElementById('cart-count');

        // 2. Get the current number inside it
        var currentCount = parseInt(countElement.innerText);

        // 3. Add 1 and put it back
        countElement.innerText = currentCount + 1;
    }
</script>


<!-- This is an invisible box that will catch the "Redirect" so your page doesn't move -->
<iframe name="hidden_iframe" id="hidden_iframe" style="display:none;"></iframe>
