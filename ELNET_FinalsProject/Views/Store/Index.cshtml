<div class ="navbar">

    <div class="nav-left">
        <h2>PICKOUT COFFEE</h2>
    </div>

    <div class="nav-center">
        <a asp-controller="Store" asp-action="Index" class="nav-link active">Home</a>
    </div>

    <div class="nav-right">
        @* <a asp-controller="Order" asp-action="Cart" class="nav-icon">
            🛒
        </a> *@
        <a asp-controller="Order" asp-action="Cart" class="nav-icon">
            🛒 <span id="cart-count" style="
                    position: absolute;
                    top: 0;
                    right: 0;
                    font-size: 10px;
                    background: #3e4e2c;
                    color: white;
                    border-radius: 50%;
                    padding: 2px 5px;
                    line-height: 1;
                    transform: translate(25%, -25%);">
                @Model.CartCount
            </span> 
        </a>

        <a href="#" class="nav-icon" onclick="openProfile(); return false;">
            👤
        </a>
    </div>

</div>
<style>
    .navbar {
        display: flex;
        justify-content: space-between;
        position: sticky; /*sticks to one place whenever you scroll*/
        top: 0;           /*sticks at the top*/
        z-index: 100;     /*ensures that it stays above other content*/
        background-color: #f5f5f5;
        
        padding: 10px 30px;
        color: #9caf6c;
    }

    .nav-center {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
    }

    .nav-link {
        text-decoration: none;
        background-color: #9caf6c;
        color: white;
        padding: 5px 20px;
        border-radius: 30px;
        transition: 0.3s ease;
    }

    .nav-link:hover {
        text-decoration: none;
        padding: 5px 30px;
        color: white;
    }

    .nav-link.active {
        border: 2px solid #9caf6c;
    }

    .nav-left h2 {
        margin: 0;
        font-weight: bold;
        font-size: 25px;
    }

    .nav-right {
        display: flex;
        gap: 20px;
    }

    .nav-icon {
        text-decoration: none;
        font-size: 25px;
        /* These 3 lines center the 🛒 perfectly */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        /* This is the secret: it keeps the bubble relative to the icon */
        position: relative;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        transition: 0.3s ease;
    }

    .nav-icon:hover {
         text-decoration: none;
         background: #9caf6c;
    }


    body {
        background-color: #f5f5f5;
        font-family: Arial, sans-serif;
    }

    .header {
        text-align: center;
        margin-bottom: 70px;
        color: #9caf6c;
    }

    .header h2 {
        font-size: 26px;

    }

    .menu-header h1 {
        text-align: center;
        color: #3e4e2c;
    }

    .signatures-header h2 {
        color: #3e4e2c
    }
    
    .espresso-header h2 {
        color: #3e4e2c
    }

    .big-title {
    text-align: center;
    margin-bottom: 30px;
    }

    .big-title h1 {
    font-size: 100px;
    font-weight: 900;
    color: #9caf6c;
    letter-spacing: 5px;
    text-shadow: 4px 4px 10px rgba(0,0,0,0.2);
    }

    .row-fluid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 30px;
        margin-top: 30px; /* ⬅️ space from header */
    }

    .card {
        width: 270px;
        padding: 15px;
        border-radius: 15px;
        background: white;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        text-align: center;
    }

    .card:hover {
        background-color: #9caf6c;
        color: white;

    }

    .card:hover .btn-cart {
        background-color: #f5f5f5;
        color: #9caf6c;

    }

    img {
        height: 280px;
        width: 100%;
        object-fit: cover;
        border-radius: 10px;
    }

    .card-title {
        font-size: 18px;
        font-weight: bold;
        color: #3e4e2c;
    }

    .card-text {
        font-size: 15px;
    }

    .card-subtitle {
        font-weight: bold;
        color: #6f4e37;
    }

    .btn-cart {
        font-weight: bold;
        background-color: #9caf6c;
        color: white;
        border: none;
        padding: 6px 10px;
        border-radius: 8px;
        margin-top: 8px;
        cursor: pointer;
    }

    .btn-cart:hover {
            background-color: #f5f5f5;
     }
</style>

