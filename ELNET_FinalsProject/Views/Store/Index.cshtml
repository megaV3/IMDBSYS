<!-- BASKET MODAL — once, outside all loops -->
<div id="basketOverlay" onclick="handleOverlayClick(event)">
    <div id="basketModal">

        <div id="bModalImgWrap">☕</div>

        <div class="modal-body">

            <div class="modal-row-header">
                <div id="bModalName"></div>
                <div id="bModalPrice"></div>
            </div>
            <p id="bModalDesc"></p>

            <div class="modal-section-label">Temperature</div>
            <div class="temp-row">
                <button id="btnHot" class="temp-btn" onclick="selectTemp('Hot')">🔥 Hot</button>
                <button id="btnIced" class="temp-btn" onclick="selectTemp('Iced')">🧊 Iced</button>
            </div>

            <div class="modal-section-label">Quantity</div>
            <div class="qty-wrapper">
                <div class="qty-row">
                    <button class="qty-btn" onclick="changeQty(-1)">−</button>
                    <span id="bQtyVal">1</span>
                    <button class="qty-btn" onclick="changeQty(1)">+</button>
                </div>
                <span id="bSubtotal"></span>
            </div>

            <div class="modal-section-label">Allergy / Dietary</div>
            <div class="allergy-chips">
                <span class="allergy-chip" onclick="toggleChip(this)">Dairy-free milk</span>
                <span class="allergy-chip" onclick="toggleChip(this)">No sugar</span>
                <span class="allergy-chip" onclick="toggleChip(this)">Less sweet</span>
                <span class="allergy-chip" onclick="toggleChip(this)">Nut allergy</span>
                <span class="allergy-chip" onclick="toggleChip(this)">Oat milk</span>
                <span class="allergy-chip" onclick="toggleChip(this)">Soy allergy</span>
            </div>

            <div class="modal-section-label">Special Instructions</div>
            <textarea id="bNotes" rows="2" placeholder="e.g. extra shot, no ice, less sweet…"></textarea>

            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeBasketModal()">Cancel</button>
                <button class="btn-add-confirm" onclick="submitBasket()">Add to Basket 🛒</button>
            </div>

        </div>
    </div>
</div>

<div id="bToast"></div>

<iframe name="hidden_iframe" id="hidden_iframe" style="display:none;"></iframe>

<script>
    var _menuId, _price, _qty = 1, _temp = 'Iced';

    function openBasketModal(menuId, name, price, desc, imgPath, canBeHot, canBeCold) {
        _menuId = menuId;
        _price  = price;
        _qty    = 1;
        _temp   = canBeCold ? 'Iced' : 'Hot';

        document.getElementById('bModalName').textContent  = name;
        document.getElementById('bModalPrice').textContent = 'PHP ' + price;
        document.getElementById('bModalDesc').textContent  = desc;
        document.getElementById('bQtyVal').textContent     = 1;
        document.getElementById('bSubtotal').textContent   = '= PHP ' + price;
        document.getElementById('bNotes').value            = '';

        document.querySelectorAll('.allergy-chip').forEach(function(c) {
            c.classList.remove('active');
        });

        var wrap = document.getElementById('bModalImgWrap');
        if (imgPath && imgPath.trim() !== '' && imgPath.trim() !== 'null') {
            wrap.innerHTML = '<img src="' + imgPath + '" alt="' + name + '" />';
        } else {
            wrap.innerHTML = '☕';
        }

        var btnHot  = document.getElementById('btnHot');
        var btnIced = document.getElementById('btnIced');
        btnHot.classList.remove('active', 'disabled');
        btnIced.classList.remove('active', 'disabled');
        if (!canBeHot)  btnHot.classList.add('disabled');
        if (!canBeCold) btnIced.classList.add('disabled');
        document.getElementById(_temp === 'Hot' ? 'btnHot' : 'btnIced').classList.add('active');

        document.getElementById('basketOverlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeBasketModal() {
        document.getElementById('basketOverlay').style.display = 'none';
        document.body.style.overflow = '';
    }

    function handleOverlayClick(e) {
        if (e.target === document.getElementById('basketOverlay')) {
            closeBasketModal();
        }
    }

    function selectTemp(t) {
        _temp = t;
        document.getElementById('btnHot').classList.toggle('active',  t === 'Hot');
        document.getElementById('btnIced').classList.toggle('active', t === 'Iced');
    }

    function changeQty(delta) {
        _qty = Math.max(1, _qty + delta);
        document.getElementById('bQtyVal').textContent   = _qty;
        document.getElementById('bSubtotal').textContent = '= PHP ' + (_price * _qty);
    }

    function toggleChip(el) {
        el.classList.toggle('active');
    }

    function submitBasket() {
        var chips = [];
        document.querySelectorAll('.allergy-chip.active').forEach(function(c) {
            chips.push(c.textContent);
        });
        var freeText = document.getElementById('bNotes').value.trim();
        var parts    = chips.join(', ');
        var notes    = (parts && freeText) ? (parts + ' | ' + freeText) : (parts || freeText);

        fetch('/Order/AddToCart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'menuId='       + encodeURIComponent(_menuId)
                + '&quantity='    + encodeURIComponent(_qty)
                + '&temperature=' + encodeURIComponent(_temp)
                + '&notes='       + encodeURIComponent(notes)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                closeBasketModal();
                updateCartCount(_qty);
                showToast('Added ' + _qty + ' item(s) to your basket! 🛒');
            }
        })
        .catch(function() {
            showToast('Something went wrong. Please try again.');
        });
    }

    function updateCartCount(added) {
        var el = document.getElementById('cart-count');
        if (el) {
            el.textContent = (parseInt(el.textContent) || 0) + added;
        }
    }

    function showToast(msg) {
        var t = document.getElementById('bToast');
        t.textContent = msg;
        t.style.opacity   = '1';
        t.style.transform = 'translateX(-50%) translateY(0)';
        setTimeout(function() {
            t.style.opacity   = '0';
            t.style.transform = 'translateX(-50%) translateY(20px)';
        }, 2800);
    }
</script>

<script>
    document.querySelectorAll('.quick-btn').forEach(button => {
        button.addEventListener('click', function() {
            document.querySelectorAll('.quick-btn'). forEach(btn => btn.classList.remove('active-menu'));

            this.classList.add('active-menu');
        });
    });
</script>